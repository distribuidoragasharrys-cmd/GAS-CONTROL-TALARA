            old = db.execute("SELECT * FROM gastos WHERE id = ?", (gasto_id,)).fetchone()
            if not old:
                raise ValueError("No se encontro el gasto seleccionado.")
            clear_account_movements(db, [f"Gasto #{gasto_id} - {old['concepto']}", f"Gasto - {old['concepto']}"])
            db.execute(
                """
                UPDATE gastos
                SET fecha = ?,
                    concepto = ?,
                    categoria = ?,
                    monto = ?,
                    observaciones = ?
                WHERE id = ?
                """,
                (fecha, concepto, categoria, monto, observaciones, gasto_id),
            )
            record_account_movement(db, fecha, "caja", "egreso", monto, f"Gasto #{gasto_id} - {concepto}")
