            """
            INSERT OR IGNORE INTO inventario_agua
                (id, llenos, vacios, entradas_mes, salidas_mes)
            VALUES
                (1, 0, 0, 0, 0)
            """
        )
        db.execute(
            """
            INSERT OR IGNORE INTO repartidores (nombre)
            SELECT DISTINCT TRIM(repartidor)
            FROM ventas
            WHERE COALESCE(TRIM(repartidor), '') != ''
            """
        )
        db.execute(
            """
            UPDATE ventas
            SET repartidor_id = (
                SELECT id
                FROM repartidores
                WHERE nombre = TRIM(ventas.repartidor)
            )
            WHERE repartidor_id IS NULL
              AND COALESCE(TRIM(repartidor), '') != ''
            """
        )
        db.execute(
            """
            UPDATE ventas
            SET total_venta = CASE
                    WHEN COALESCE(total_venta, 0) = 0 THEN COALESCE(NULLIF(monto, 0), precio_venta * cantidad, 0)
                    ELSE total_venta
                END,
                precio_venta = CASE
                    WHEN COALESCE(precio_venta, 0) = 0 AND COALESCE(cantidad, 0) > 0
                    THEN COALESCE(NULLIF(monto, 0), total_venta, 0) / cantidad
                    ELSE precio_venta
                END,
                total_costo = CASE
                    WHEN COALESCE(total_costo, 0) = 0 THEN COALESCE(costo_balon, 0) * COALESCE(cantidad, 1)
                    ELSE total_costo
                END
            """
        )
        db.execute(
            """
            UPDATE ventas
            SET producto = COALESCE(NULLIF(producto, ''), 'BALON DE GAS 10 KG'),
                tipo_valvula = CASE
                    WHEN COALESCE(NULLIF(tipo_valvula, ''), '') = '' THEN 'VALVULA NORMAL'
                    ELSE tipo_valvula
                END
            """
        )
        db.execute(
            """
            UPDATE pedidos
            SET producto = COALESCE(NULLIF(producto, ''), 'BALON DE GAS 10 KG'),
                tipo_valvula = CASE
                    WHEN COALESCE(NULLIF(producto, ''), 'BALON DE GAS 10 KG') LIKE '%GAS%'
                     AND COALESCE(NULLIF(tipo_valvula, ''), '') = '' THEN 'VALVULA NORMAL'
                    WHEN COALESCE(NULLIF(producto, ''), 'BALON DE GAS 10 KG') LIKE '%AGUA%' THEN ''
                    ELSE COALESCE(tipo_valvula, '')
                END,
                ganancia_estimada = CASE
                    WHEN COALESCE(ganancia_estimada, 0) = 0
                    THEN (COALESCE(precio_venta, 0) - COALESCE(costo_producto, 0)) * COALESCE(cantidad, 1)
                    ELSE ganancia_estimada
                END
            """
        )
        db.execute(
            """
            INSERT INTO pedido_items
                (pedido_id, producto, tipo_valvula, cantidad, costo_unitario, precio_unitario,
                 total_costo, total_venta, ganancia)
            SELECT p.id,
                   COALESCE(NULLIF(p.producto, ''), 'BALON DE GAS 10 KG'),
                   COALESCE(p.tipo_valvula, ''),
                   COALESCE(p.cantidad, 1),
                   COALESCE(p.costo_producto, 0),
                   COALESCE(p.precio_venta, 0),
                   COALESCE(p.costo_producto, 0) * COALESCE(p.cantidad, 1),
                   COALESCE(p.precio_venta, 0) * COALESCE(p.cantidad, 1),
                   (COALESCE(p.precio_venta, 0) - COALESCE(p.costo_producto, 0)) * COALESCE(p.cantidad, 1)
            FROM pedidos p
            WHERE NOT EXISTS (
                SELECT 1 FROM pedido_items pi WHERE pi.pedido_id = p.id
            )
            """
        )
        db.execute(
            """
            INSERT INTO venta_items
                (venta_id, producto, tipo_valvula, cantidad, costo_unitario, precio_unitario,
                 total_costo, total_venta, ganancia)
            SELECT v.id,
                   COALESCE(NULLIF(v.producto, ''), 'BALON DE GAS 10 KG'),
                   COALESCE(v.tipo_valvula, ''),
                   COALESCE(v.cantidad, 1),
                   COALESCE(v.costo_balon, 0),
                   COALESCE(v.precio_venta, 0),
                   COALESCE(v.total_costo, COALESCE(v.costo_balon, 0) * COALESCE(v.cantidad, 1)),
                   COALESCE(v.total_venta, COALESCE(v.precio_venta, 0) * COALESCE(v.cantidad, 1)),
                   COALESCE(v.ganancia, 0)
            FROM ventas v
            WHERE NOT EXISTS (
                SELECT 1 FROM venta_items vi WHERE vi.venta_id = v.id
            )
            """
        )
        db.execute(
            """
            UPDATE pedidos
            SET items_resumen = COALESCE(NULLIF(items_resumen, ''), producto || ' x ' || cantidad)
            """
        )
        db.execute(
            """
            UPDATE ventas
            SET items_resumen = COALESCE(NULLIF(items_resumen, ''), producto || ' x ' || cantidad)
            """
        )
        db.execute(
            """
            UPDATE ventas
            SET ganancia = CASE
                    WHEN COALESCE(ganancia, 0) = 0 THEN COALESCE(total_venta, 0) - COALESCE(total_costo, 0)
                    ELSE ganancia
                END,
                dinero_entregado = CASE
                    WHEN COALESCE(dinero_entregado, 0) = 0 THEN COALESCE(total_venta, monto, 0)
                    ELSE dinero_entregado
                END
            """
        )
        db.execute(
            """
            UPDATE ventas
            SET dinero_pendiente = MAX(COALESCE(total_venta, 0) - COALESCE(dinero_entregado, 0), 0),
                pago_efectivo = CASE
                    WHEN COALESCE(pago_efectivo, 0) = 0
                     AND COALESCE(pago_yape, 0) = 0
                     AND COALESCE(pago_yape_marcos, 0) = 0
                     AND COALESCE(pago_plin, 0) = 0
                     AND COALESCE(pago_fise, 0) = 0
                     AND COALESCE(pago_fiado, 0) = 0
                    THEN COALESCE(dinero_entregado, total_venta, monto, 0)
                    ELSE pago_efectivo
                END,
                pago_fiado = CASE
                    WHEN COALESCE(pago_efectivo, 0) = 0
                     AND COALESCE(pago_yape, 0) = 0
                     AND COALESCE(pago_yape_marcos, 0) = 0
                     AND COALESCE(pago_plin, 0) = 0
                     AND COALESCE(pago_fise, 0) = 0
                     AND COALESCE(pago_fiado, 0) = 0
                    THEN MAX(COALESCE(total_venta, 0) - COALESCE(dinero_entregado, 0), 0)
                    ELSE pago_fiado
                END,
                monto = CASE
                    WHEN COALESCE(monto, 0) = 0 THEN COALESCE(total_venta, 0)
                    ELSE monto
                END
            """
        )
        db.execute(
            """
            INSERT OR IGNORE INTO ganancias (venta_id, fecha, repartidor_id, ganancia)
            SELECT id, fecha, repartidor_id, ganancia
            FROM ventas
            """
        )
        for tipo in PAYMENT_METHODS:
            column = f"pago_{tipo}"
            db.execute(
                f"""
                INSERT OR IGNORE INTO pagos_venta (venta_id, tipo, monto)
                SELECT id, ?, COALESCE({column}, 0)
                FROM ventas
                WHERE COALESCE({column}, 0) > 0
                """,
                (tipo,),
            )
        db.commit()


def soles(value):
    return f"S/ {float(value or 0):,.2f}"


app.jinja_env.filters["soles"] = soles


def today_iso():
    return date.today().isoformat()


def parse_iso_date(value, fallback=None):
    fallback = fallback or date.today()
    try:
        return datetime.strptime(value, "%Y-%m-%d").date()
    except (TypeError, ValueError):
        return fallback


def selected_date_from_request():
    return parse_iso_date(request.args.get("fecha"))


def month_start_iso(base_date):
    return base_date.replace(day=1).isoformat()


def format_date(value):
    try:
        return datetime.strptime(value, "%Y-%m-%d").strftime("%d/%m/%Y")
    except (TypeError, ValueError):
        return value or ""


def order_state_label(value):
    labels = {
        "pendiente": "Pendiente",
        "en_ruta": "En ruta",
        "entregado": "Entregado",
        "liquidado": "Liquidado",
        "anulado": "Anulado",
    }
    return labels.get(value, value or "")


def product_category(product):
    return "gas" if product in GAS_PRODUCTS else "agua" if product in WATER_PRODUCTS else "otro"


def validate_product_fields(product, valve):
    if product not in PRODUCTS:
        raise ValueError("Seleccione un producto valido.")
    if product_category(product) == "gas":
        if valve not in GAS_VALVES:
            raise ValueError("Seleccione el tipo de valvula para gas.")
        return valve
    return ""


def affects_gas_inventory(product):
    return not product or product_category(product) == "gas"


def affects_water_inventory(product):
    return product_category(product) == "agua"


def build_item(product, valve, quantity, cost, price):
    clean_valve = validate_product_fields(product, valve)
    if quantity <= 0:
        raise ValueError("La cantidad debe ser mayor a cero.")
    if cost < 0:
        raise ValueError("El costo no puede ser negativo.")
    if price <= 0:
        raise ValueError("El precio de venta debe ser mayor a cero.")
    total_cost = cost * quantity
    total_sale = price * quantity
    return {
        "producto": product,
        "tipo_valvula": clean_valve,
        "cantidad": int(quantity),
        "costo_unitario": float(cost),
        "precio_unitario": float(price),
        "total_costo": float(total_cost),
        "total_venta": float(total_sale),
        "ganancia": float(total_sale - total_cost),
    }


def item_totals(items):
    return {
        "cantidad": sum(int(item["cantidad"]) for item in items),
        "total_costo": sum(float(item["total_costo"]) for item in items),
        "total_venta": sum(float(item["total_venta"]) for item in items),
        "ganancia": sum(float(item["ganancia"]) for item in items),
    }


def summarize_items(items):
    if not items:
        return ""
    return " + ".join(f"{item['cantidad']} x {item['producto']}" for item in items)


def parse_order_items_from_form():
    items = [
        build_item(
            text_from_form("producto"),
            text_from_form("tipo_valvula"),
            number_from_form("cantidad", default=1, integer=True),
            number_from_form("costo_producto"),
            number_from_form("precio_venta"),
        )
    ]
    extra_product = text_from_form("producto_extra")
    if extra_product:
        items.append(
            build_item(
                extra_product,
                text_from_form("tipo_valvula_extra"),
                number_from_form("cantidad_extra", integer=True),
                number_from_form("costo_producto_extra"),
                number_from_form("precio_venta_extra"),
            )
        )
    return items


def date_label(base_date):
    months = [
        "enero",
        "febrero",
        "marzo",
        "abril",
        "mayo",
        "junio",
        "julio",
        "agosto",
        "septiembre",
        "octubre",
        "noviembre",
        "diciembre",
    ]
    return f"{base_date.day:02d} {months[base_date.month - 1]} {base_date.year}"


def number_from_form(name, default=0, integer=False):
    raw_value = (request.form.get(name) or "").strip()
    if not raw_value:
        return default
    try:
        value = float(raw_value.replace(",", "."))
    except ValueError as error:
        raise ValueError("Ingrese un numero valido.") from error
    return int(value) if integer else value


def text_from_form(name):
    return (request.form.get(name) or "").strip()


def one_value(db, query, params=()):
    row = db.execute(query, params).fetchone()
    if row is None:
        return 0
    if isinstance(row, dict):
        return next(iter(row.values())) or 0
    return list(row)[0] or 0


def get_or_create_driver(db, name):
    clean_name = " ".join(name.strip().split())
    if not clean_name:
        raise ValueError("Ingrese el nombre del repartidor.")

    db.execute("INSERT OR IGNORE INTO repartidores (nombre) VALUES (?)", (clean_name,))
    row = db.execute("SELECT id, nombre FROM repartidores WHERE nombre = ?", (clean_name,)).fetchone()
    return row["id"], row["nombre"]


def get_account_id(db, codigo):
    row = db.execute("SELECT id FROM cuentas_bancarias WHERE codigo = ?", (codigo,)).fetchone()
    return row["id"] if row else None


def record_account_movement(db, fecha, codigo, tipo, monto, referencia):
    if monto <= 0:
        return
    account_id = get_account_id(db, codigo)
    if account_id is None:
        return
    db.execute(
        """
        INSERT INTO movimientos_cuentas (fecha, cuenta_id, tipo, monto, referencia)
        VALUES (?, ?, ?, ?, ?)
        """,
        (fecha, account_id, tipo, monto, referencia),
    )


def log_change(db, table_name, record_id, action, detail=""):
    db.execute(
        """
        INSERT INTO auditoria_cambios (tabla, registro_id, accion, detalle)
        VALUES (?, ?, ?, ?)
        """,
        (table_name, record_id, action, detail),
    )


def clear_account_movements(db, references):
    for reference in references:
        if reference:
            db.execute("DELETE FROM movimientos_cuentas WHERE referencia = ?", (reference,))


def clear_sale_account_movements(db, venta_id):
    db.execute("DELETE FROM movimientos_cuentas WHERE referencia LIKE ?", (f"Venta #{venta_id} - %",))


def clear_order_account_movements(db, pedido_id):
    db.execute("DELETE FROM movimientos_cuentas WHERE referencia LIKE ?", (f"Pedido #{pedido_id} - %",))
    db.execute("DELETE FROM movimientos_cuentas WHERE referencia = ?", (f"Liquidacion pedido #{pedido_id}",))


def payment_amounts_from_form(prefix="pago_"):
    return {method: number_from_form(f"{prefix}{method}") for method in PAYMENT_METHODS}


def fise_counts_from_form(prefix=""):
    cantidad_20 = number_from_form(f"{prefix}fise_20_cantidad", integer=True)
    cantidad_43 = number_from_form(f"{prefix}fise_43_cantidad", integer=True)
    if cantidad_20 < 0 or cantidad_43 < 0:
        raise ValueError("Las cantidades de FISE no pueden ser negativas.")
    return {
        "cantidad_20": cantidad_20,
        "cantidad_43": cantidad_43,
        "cantidad_total": cantidad_20 + cantidad_43,
        "valor_total": (cantidad_20 * FISE_20_VALUE) + (cantidad_43 * FISE_43_VALUE),
    }


def liquidation_amounts_from_form(prefix="pago_"):
    payments = payment_amounts_from_form(prefix)
    fise_counts = fise_counts_from_form()
    if fise_counts["cantidad_total"] > 0:
        payments["fise"] = float(fise_counts["valor_total"])
    vuelto_yape = number_from_form("vuelto_yape")
    if vuelto_yape < 0:
        raise ValueError("El vuelto por Yape no puede ser negativo.")
    return payments, fise_counts, vuelto_yape


def total_payment_amount(payments):
    return sum(float(value or 0) for value in payments.values())


def net_payment_amount(payments, vuelto_yape=0):
    return total_payment_amount(payments) - float(vuelto_yape or 0)


def save_sale_payments(db, venta_id, payments):
    db.execute("DELETE FROM pagos_venta WHERE venta_id = ?", (venta_id,))
    for tipo, monto in payments.items():
        if monto > 0:
            db.execute(
                "INSERT INTO pagos_venta (venta_id, tipo, monto) VALUES (?, ?, ?)",
                (venta_id, tipo, monto),
            )


def payment_amounts_from_row(row):
    return {method: float(row[f"pago_{method}"] or 0) for method in PAYMENT_METHODS}


def record_payment_account_movements(db, fecha, payments, reference_prefix):
    for tipo, monto in payments.items():
        account_code = PAYMENT_TO_ACCOUNT.get(tipo)
        if account_code:
            record_account_movement(
                db,
                fecha,
                account_code,
                "ingreso",
                float(monto or 0),
                f"{reference_prefix} - {tipo.replace('_', ' ').title()}",
            )


def record_vuelto_yape_movement(db, fecha, vuelto_yape, reference_prefix):
    record_account_movement(db, fecha, "yape", "egreso", float(vuelto_yape or 0), f"{reference_prefix} - Vuelto Yape")


def adjust_inventory_for_sale_delta(db, quantity_delta):
    if quantity_delta == 0:
        return
    if quantity_delta > 0:
        inventory = db.execute("SELECT llenos FROM inventario WHERE id = 1").fetchone()
        if inventory["llenos"] < quantity_delta:
            raise ValueError("No hay stock suficiente para este cambio.")
    db.execute(
        """
        UPDATE inventario
        SET llenos = llenos - ?,
            vacios = vacios + ?,
            salidas_mes = MAX(salidas_mes + ?, 0),
            updated_at = CURRENT_TIMESTAMP
        WHERE id = 1
        """,
        (quantity_delta, quantity_delta, quantity_delta),
    )


def adjust_water_inventory_for_sale_delta(db, quantity_delta):
    if quantity_delta == 0:
        return
    if quantity_delta > 0:
        inventory = db.execute("SELECT llenos FROM inventario_agua WHERE id = 1").fetchone()
        if inventory["llenos"] < quantity_delta:
            raise ValueError("No hay stock suficiente de agua para este cambio.")
    db.execute(
        """
        UPDATE inventario_agua
        SET llenos = llenos - ?,
            vacios = vacios + ?,
            salidas_mes = MAX(salidas_mes + ?, 0),
            updated_at = CURRENT_TIMESTAMP
        WHERE id = 1
        """,
        (quantity_delta, quantity_delta, quantity_delta),
    )


def adjust_inventory_for_product_delta(db, product, quantity_delta):
    if affects_gas_inventory(product):
        adjust_inventory_for_sale_delta(db, quantity_delta)
    elif affects_water_inventory(product):
        adjust_water_inventory_for_sale_delta(db, quantity_delta)


def adjust_inventory_for_items(db, items, quantity_multiplier=1):
    for item in items:
        adjust_inventory_for_product_delta(db, item["producto"], int(item["cantidad"]) * quantity_multiplier)


def record_inventory_movements_for_items(db, fecha, items, reference, movement_type):
    for item in items:
        quantity = int(item["cantidad"])
        product = item["producto"]
        if affects_gas_inventory(product):
            db.execute(
                """
                INSERT INTO movimientos_inventario
                    (fecha, tipo, cantidad_llenos, cantidad_vacios, referencia)
                VALUES (?, ?, ?, ?, ?)
                """,
                (fecha, movement_type, -quantity, quantity, reference),
            )
        elif affects_water_inventory(product):
            db.execute(
                """
                INSERT INTO movimientos_agua
                    (fecha, tipo, cantidad_llenos, cantidad_vacios, referencia)
                VALUES (?, ?, ?, ?, ?)
                """,
                (fecha, movement_type, -quantity, quantity, reference),
            )


def save_order_items(db, pedido_id, items):
    db.execute("DELETE FROM pedido_items WHERE pedido_id = ?", (pedido_id,))
    for item in items:
        db.execute(
            """
            INSERT INTO pedido_items
                (pedido_id, producto, tipo_valvula, cantidad, costo_unitario, precio_unitario,
                 total_costo, total_venta, ganancia)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (
                pedido_id,
                item["producto"],
                item["tipo_valvula"],
                item["cantidad"],
                item["costo_unitario"],
                item["precio_unitario"],
                item["total_costo"],
                item["total_venta"],
                item["ganancia"],
            ),
        )


def save_sale_items(db, venta_id, items):
    db.execute("DELETE FROM venta_items WHERE venta_id = ?", (venta_id,))
    for item in items:
        db.execute(
            """
            INSERT INTO venta_items
                (venta_id, producto, tipo_valvula, cantidad, costo_unitario, precio_unitario,
                 total_costo, total_venta, ganancia)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (
                venta_id,
                item["producto"],
                item["tipo_valvula"],
                item["cantidad"],
                item["costo_unitario"],
                item["precio_unitario"],
                item["total_costo"],
                item["total_venta"],
                item["ganancia"],
            ),
        )


def rows_to_items(rows):
    return [
        {
            "producto": row["producto"],
            "tipo_valvula": row["tipo_valvula"] or "",
            "cantidad": int(row["cantidad"] or 0),
            "costo_unitario": float(row["costo_unitario"] or 0),
            "precio_unitario": float(row["precio_unitario"] or 0),
            "total_costo": float(row["total_costo"] or 0),
            "total_venta": float(row["total_venta"] or 0),
            "ganancia": float(row["ganancia"] or 0),
        }
        for row in rows
    ]


def get_order_items(db, pedido):
    rows = db.execute(
        """
        SELECT producto, tipo_valvula, cantidad, costo_unitario, precio_unitario,
               total_costo, total_venta, ganancia
        FROM pedido_items
        WHERE pedido_id = ?
        ORDER BY id
        """,
        (pedido["id"],),
    ).fetchall()
    items = rows_to_items(rows)
    if items:
        return items
    return [
        build_item(
            pedido["producto"] or "BALON DE GAS 10 KG",
            pedido["tipo_valvula"] or "VALVULA NORMAL",
            int(pedido["cantidad"] or 1),
            float(pedido["costo_producto"] or 0),
            float(pedido["precio_venta"] or 0),
        )
    ]


def get_sale_items(db, sale):
    rows = db.execute(
        """
        SELECT producto, tipo_valvula, cantidad, costo_unitario, precio_unitario,
               total_costo, total_venta, ganancia
        FROM venta_items
        WHERE venta_id = ?
        ORDER BY id
        """,
        (sale["id"],),
    ).fetchall()
    items = rows_to_items(rows)
    if items:
        return items
    return [
        build_item(
            sale["producto"] or "BALON DE GAS 10 KG",
            sale["tipo_valvula"] or "VALVULA NORMAL",
            int(sale["cantidad"] or 1),
            float(sale["costo_balon"] or 0),
            float(sale["precio_venta"] or 0),
        )
    ]


def get_daily_price(db, selected_date):
    row = db.execute(
        """
        SELECT fecha, costo_balon, precio_venta
        FROM precios_gas
        WHERE fecha <= ?
        ORDER BY fecha DESC
        LIMIT 1
        """,
        (selected_date.isoformat(),),
    ).fetchone()
    if row:
        return {
            "fecha": row["fecha"],
            "costo_balon": float(row["costo_balon"] or 0),
            "precio_venta": float(row["precio_venta"] or 0),
        }
    return {"fecha": selected_date.isoformat(), "costo_balon": 0, "precio_venta": 0}


def build_price_history(db):
    return [
        {
            "fecha": format_date(row["fecha"]),
            "costo_balon": float(row["costo_balon"] or 0),
            "precio_venta": float(row["precio_venta"] or 0),
        }
        for row in db.execute(
            """
            SELECT fecha, costo_balon, precio_venta
            FROM precios_gas
            ORDER BY fecha DESC
            LIMIT 8
            """
        ).fetchall()
    ]


def build_sales_chart(db, selected_date):
    start = selected_date - timedelta(days=6)
    rows = db.execute(
        """
        SELECT fecha, COALESCE(SUM(total_venta), 0) AS total
        FROM ventas
        WHERE fecha BETWEEN ? AND ?
        GROUP BY fecha
        """,
        (start.isoformat(), selected_date.isoformat()),
    ).fetchall()
    totals_by_date = {row["fecha"]: row["total"] for row in rows}

    chart = []
    for offset in range(7):
        day = start + timedelta(days=offset)
        chart.append({"day": day.strftime("%d/%m"), "value": float(totals_by_date.get(day.isoformat(), 0))})
    return chart


def build_expense_categories(db, selected_date):
    rows = db.execute(
        """
        SELECT categoria, COALESCE(SUM(monto), 0) AS total
        FROM gastos
        WHERE fecha >= ? AND fecha <= ?
        GROUP BY categoria
        ORDER BY total DESC
        """,
        (month_start_iso(selected_date), selected_date.isoformat()),
    ).fetchall()
    colors = ["#0b75d1", "#ef4444", "#10b981", "#f59e0b", "#7c3aed", "#0ea5e9"]
    expense_total = sum(float(row["total"] or 0) for row in rows)

    categories = []
    for index, row in enumerate(rows):
        amount = float(row["total"] or 0)
        percent = round((amount / expense_total) * 100) if expense_total else 0
        categories.append(
            {
                "label": row["categoria"],
                "amount": amount,
                "value": soles(amount),
                "percent": f"{percent}%",
                "color": colors[index % len(colors)],
            }
        )
    return categories, expense_total


def build_payment_summary(db, selected_date):
    row = db.execute(
        """
        SELECT COALESCE(SUM(pago_efectivo), 0) AS efectivo,
               COALESCE(SUM(pago_yape), 0) AS yape,
               COALESCE(SUM(pago_yape_marcos), 0) AS yape_marcos,
               COALESCE(SUM(pago_plin), 0) AS plin,
               COALESCE(SUM(pago_fise), 0) AS fise,
               COALESCE(SUM(pago_fiado), 0) AS fiado,
               COALESCE(SUM(pago_vuelto_yape), 0) AS vuelto_yape,
               COALESCE(SUM(total_venta), 0) AS total
        FROM ventas
        WHERE fecha = ?
        """,
        (selected_date.isoformat(),),
    ).fetchone()
    efectivo = float(row["efectivo"] or 0)
    yape = float(row["yape"] or 0)
    yape_marcos = float(row["yape_marcos"] or 0)
    plin = float(row["plin"] or 0)
    fise = float(row["fise"] or 0)
    fiado = float(row["fiado"] or 0)
    vuelto_yape = float(row["vuelto_yape"] or 0)
    total = float(row["total"] or 0)
    return {
        "efectivo": efectivo,
        "yape": yape,
        "yape_marcos": yape_marcos,
        "plin": plin,
        "fise": fise,
        "fiado": fiado,
        "vuelto_yape": vuelto_yape,
        "total": total,
        "cuadre": round(efectivo + yape + yape_marcos + plin + fise + fiado - vuelto_yape, 2) == round(total, 2),
    }


def build_stock_control(db, selected_date, inventory):
    selected_iso = selected_date.isoformat()
    stock_row = db.execute("SELECT * FROM stock_diario WHERE fecha = ?", (selected_iso,)).fetchone()
    inicio_llenos = int(stock_row["inicio_llenos"]) if stock_row else None
    ventas_pedidos = int(
        one_value(
            db,
            """
            SELECT COALESCE(SUM(pi.cantidad), 0)
            FROM pedido_items pi
            JOIN pedidos p ON p.id = pi.pedido_id
            WHERE p.fecha = ?
              AND p.estado IN ('entregado', 'liquidado')
              AND pi.producto LIKE '%GAS%'
            """,
            (selected_iso,),
        )
    )
    ventas_directas = int(
        one_value(
            db,
            """
            SELECT COALESCE(SUM(vi.cantidad), 0)
            FROM venta_items vi
            JOIN ventas v ON v.id = vi.venta_id
            WHERE v.fecha = ?
              AND v.pedido_id IS NULL
              AND vi.producto LIKE '%GAS%'
            """,
            (selected_iso,),
        )
    )
    ventas = ventas_pedidos + ventas_directas
    prestamos_llenos = int(
        one_value(
            db,
            """
            SELECT COALESCE(SUM(cantidad - devueltos), 0)
            FROM prestamos
            WHERE fecha = ? AND tipo_balon = 'lleno'
            """,
            (selected_iso,),
        )
    )
    salidas = ventas + prestamos_llenos
    stock_final = None if inicio_llenos is None else max(inicio_llenos - salidas, 0)
    diferencia = None if stock_final is None else int(inventory["llenos"]) - stock_final
    return {
        "inicio_llenos": inicio_llenos,
        "ventas": ventas,
        "prestamos_llenos": prestamos_llenos,
        "salidas": salidas,
        "stock_final": stock_final,
        "inventario_actual": int(inventory["llenos"]),
        "diferencia": diferencia,
        "cuadra": diferencia == 0 if diferencia is not None else False,
    }


def build_water_inventory_report(db, selected_date, water_inventory):
    selected_iso = selected_date.isoformat()
    sales = int(
        one_value(
            db,
            """
            SELECT COALESCE(SUM(vi.cantidad), 0)
            FROM venta_items vi
            JOIN ventas v ON v.id = vi.venta_id
            WHERE v.fecha = ? AND vi.producto LIKE '%AGUA%'
            """,
            (selected_iso,),
        )
    )
    movements = [
        {
            "fecha": format_date(row["fecha"]),
            "tipo": row["tipo"],
            "llenos": int(row["cantidad_llenos"] or 0),
            "vacios": int(row["cantidad_vacios"] or 0),
            "referencia": row["referencia"] or "",
        }
        for row in db.execute(
            """
            SELECT fecha, tipo, cantidad_llenos, cantidad_vacios, referencia
            FROM movimientos_agua
            WHERE fecha = ?
            ORDER BY created_at DESC, id DESC
            LIMIT 8
            """,
            (selected_iso,),
        ).fetchall()
    ]
    return {
        "llenos": int(water_inventory["llenos"]),
        "vacios": int(water_inventory["vacios"]),
        "entradas_mes": int(water_inventory["entradas_mes"]),
        "salidas_mes": int(water_inventory["salidas_mes"]),
        "ventas": sales,
        "movements": movements,
    }


