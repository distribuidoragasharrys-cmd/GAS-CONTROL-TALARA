@app.route("/fises-liquidacion/entregar", methods=["POST"])
def entregar_fises_fisicos():
    fecha = text_from_form("fecha") or today_iso()
    try:
        repartidor_id = number_from_form("repartidor_id", integer=True)
        cantidad_20 = number_from_form("cantidad_20", integer=True)
        cantidad_43 = number_from_form("cantidad_43", integer=True)
        observaciones = text_from_form("observaciones")
        if cantidad_20 < 0 or cantidad_43 < 0:
            raise ValueError("Las cantidades de FISE no pueden ser negativas.")
        if cantidad_20 == 0 and cantidad_43 == 0:
            raise ValueError("No hay FISES pendientes para marcar como entregados.")
        with get_connection() as db:
            driver = db.execute("SELECT id FROM repartidores WHERE id = ?", (repartidor_id,)).fetchone()
            if not driver:
                raise ValueError("No se encontro el repartidor.")
            total = cantidad_20 + cantidad_43
            total_fise = (cantidad_20 * FISE_20_VALUE) + (cantidad_43 * FISE_43_VALUE)
            db.execute(
                """
                INSERT INTO fise_entregas
                    (fecha, repartidor_id, cantidad_20, cantidad_43, cantidad_total,
                     total_fise, usuario, observaciones)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
                """,
                (fecha, repartidor_id, cantidad_20, cantidad_43, total, total_fise, session.get("usuario", ""), observaciones),
            )
            db.commit()
        flash("FISES fisicos marcados como entregados.", "success")
    except ValueError as error:
        flash(str(error), "danger")
    return redirect_to_dashboard(fecha, "fiseLiquidationPanel")


@app.route("/fiados/<int:venta_id>/liquidar", methods=["POST"])
def liquidar_fiado(venta_id):
    fecha = text_from_form("fecha_pago") or today_iso()
    try:
        metodo_pago = text_from_form("metodo_pago") or "mixto"
        if metodo_pago not in {"efectivo", "yape", "transferencia", "fise", "mixto"}:
            raise ValueError("Seleccione un metodo de pago valido.")
        pago_efectivo = number_from_form("pago_efectivo")
        pago_yape = number_from_form("pago_yape")
        pago_transferencia = number_from_form("pago_transferencia")
        fise_counts = fise_counts_from_form()
        pago_fise = fise_counts["valor_total"] or number_from_form("pago_fise")
        observaciones = text_from_form("observaciones")
        amounts = [pago_efectivo, pago_yape, pago_transferencia, pago_fise]
        if min(amounts) < 0:
            raise ValueError("Los montos no pueden ser negativos.")
        total_pagado = sum(amounts)
        if total_pagado <= 0:
            raise ValueError("Ingrese un monto para liquidar la deuda.")

        with get_connection() as db:
            venta = db.execute("SELECT * FROM ventas WHERE id = ?", (venta_id,)).fetchone()
            if not venta:
                raise ValueError("No se encontro la venta fiada.")
            deuda_original = float(venta["pago_fiado"] or 0)
            pagado = float(one_value(db, "SELECT COALESCE(SUM(total_pagado), 0) FROM fiado_pagos WHERE venta_id = ?", (venta_id,)))
            pendiente = max(deuda_original - pagado, 0)
            if pendiente <= 0:
                raise ValueError("Esta deuda ya fue liquidada.")
            if round(total_pagado, 2) > round(pendiente, 2):
                raise ValueError("El pago no puede ser mayor al monto pendiente.")
            db.execute(
                """
                INSERT INTO fiado_pagos
                    (venta_id, fecha_pago, metodo_pago, pago_efectivo, pago_yape,
                     pago_transferencia, pago_fise, fise_20_cantidad, fise_43_cantidad,
                     total_pagado, usuario, observaciones)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """,
                (
                    venta_id,
                    fecha,
                    metodo_pago,
                    pago_efectivo,
                    pago_yape,
                    pago_transferencia,
                    pago_fise,
                    fise_counts["cantidad_20"],
                    fise_counts["cantidad_43"],
                    total_pagado,
                    session.get("usuario", ""),
                    observaciones,
                ),
            )
            if pago_efectivo:
                record_account_movement(db, fecha, "caja", "ingreso", pago_efectivo, f"Pago fiado venta #{venta_id} - Efectivo")
            if pago_yape:
                record_account_movement(db, fecha, "yape", "ingreso", pago_yape, f"Pago fiado venta #{venta_id} - Yape")
            if pago_transferencia:
                record_account_movement(db, fecha, "bcp", "ingreso", pago_transferencia, f"Pago fiado venta #{venta_id} - Transferencia")
            if pago_fise:
                record_account_movement(db, fecha, "fise", "ingreso", pago_fise, f"Pago fiado venta #{venta_id} - FISE")
            log_change(db, "fiado_pagos", venta_id, "liquidar", f"Pago fiado registrado por {session.get('usuario', '')}")
            db.commit()
        flash("Deuda fiada liquidada correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")
    return redirect_to_dashboard(fecha, "clientesFiadosPanel")


@app.route("/liquidaciones/<int:liquidacion_id>/editar", methods=["POST"])
def editar_liquidacion(liquidacion_id):
    fecha = text_from_form("fecha") or today_iso()
    try:
        payments = payment_amounts_from_form()
        vuelto_yape = number_from_form("pago_vuelto_yape")
        entregado = number_from_form("dinero_entregado")
        observaciones = text_from_form("observaciones")
        if min(payments.values()) < 0 or entregado < 0 or vuelto_yape < 0:
            raise ValueError("Los montos no pueden ser negativos.")

        with get_connection() as db:
            liquidacion = db.execute("SELECT * FROM liquidaciones_repartidores WHERE id = ?", (liquidacion_id,)).fetchone()
            if not liquidacion:
                raise ValueError("No se encontro la liquidacion seleccionada.")
            fecha = text_from_form("fecha") or liquidacion["fecha"]
            venta = None
            if liquidacion["venta_id"]:
                venta = db.execute("SELECT * FROM ventas WHERE id = ?", (liquidacion["venta_id"],)).fetchone()

            if venta:
                total_venta = float(venta["total_venta"] or 0)
                if round(net_payment_amount(payments, vuelto_yape), 2) != round(total_venta, 2):
                    raise ValueError("Los pagos deben sumar exactamente el total de la venta.")
                dinero_pendiente = payments["fiado"] + max(payments["efectivo"] - entregado, 0)
                db.execute(
                    """
                    UPDATE ventas
                    SET fecha = ?,
                        pago_efectivo = ?,
                        pago_yape = ?,
                        pago_yape_marcos = ?,
                        pago_plin = ?,
                        pago_fise = ?,
                        pago_fiado = ?,
                        pago_vuelto_yape = ?,
                        dinero_entregado = ?,
                        dinero_pendiente = ?,
                        observaciones = ?
                    WHERE id = ?
                    """,
                    (
                        fecha,
                        payments["efectivo"],
                        payments["yape"],
                        payments["yape_marcos"],
                        payments["plin"],
                        payments["fise"],
                        payments["fiado"],
                        vuelto_yape,
                        entregado,
                        dinero_pendiente,
                        observaciones,
                        venta["id"],
                    ),
                )
                save_sale_payments(db, venta["id"], payments)
                if venta["pedido_id"]:
                    pedido_id = int(venta["pedido_id"])
                    clear_order_account_movements(db, pedido_id)
                    record_payment_account_movements(db, fecha, payments, f"Pedido #{pedido_id}")
                    record_vuelto_yape_movement(db, fecha, vuelto_yape, f"Pedido #{pedido_id}")
                    record_account_movement(db, fecha, "caja", "ingreso", entregado, f"Liquidacion pedido #{pedido_id}")
                else:
                    clear_sale_account_movements(db, venta["id"])
                    record_payment_account_movements(db, fecha, payments, f"Venta #{venta['id']}")
                    record_vuelto_yape_movement(db, fecha, vuelto_yape, f"Venta #{venta['id']}")
            db.execute(
                """
                UPDATE liquidaciones_repartidores
                SET fecha = ?,
                    debe_entregar = ?,
                    entregado = ?,
                    diferencia = ?,
                    vuelto_yape = ?,
                    observaciones = ?
                WHERE id = ?
                """,
                (fecha, payments["efectivo"], entregado, entregado - payments["efectivo"], vuelto_yape, observaciones, liquidacion_id),
            )
            log_change(db, "liquidaciones_repartidores", liquidacion_id, "editar", "Liquidacion actualizada")
            db.commit()
        flash("Liquidacion actualizada correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")
    return redirect_to_dashboard(fecha, "repartidoresPanel")


@app.route("/liquidaciones/<int:liquidacion_id>/eliminar", methods=["POST"])
def eliminar_liquidacion(liquidacion_id):
    fecha = text_from_form("fecha") or today_iso()
    try:
        with get_connection() as db:
            liquidacion = db.execute(
                """
                SELECT l.*, r.nombre AS repartidor
                FROM liquidaciones_repartidores l
                LEFT JOIN repartidores r ON r.id = l.repartidor_id
                WHERE l.id = ?
                """,
                (liquidacion_id,),
            ).fetchone()
            if not liquidacion:
                raise ValueError("No se encontro la liquidacion seleccionada.")
            fecha = liquidacion["fecha"]
            if liquidacion["venta_id"]:
                delete_sale_record(db, int(liquidacion["venta_id"]))
            else:
                clear_account_movements(db, [f"Liquidacion - {liquidacion['repartidor']}"])
                db.execute("DELETE FROM liquidaciones_repartidores WHERE id = ?", (liquidacion_id,))
            log_change(db, "liquidaciones_repartidores", liquidacion_id, "eliminar", "Liquidacion eliminada")
            db.commit()
        flash("Liquidacion eliminada correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")
    return redirect_to_dashboard(fecha, "repartidoresPanel")


