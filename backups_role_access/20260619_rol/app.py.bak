        for row in gas_rows
    ]


def build_fise_report(db, selected_date):
    selected_iso = selected_date.isoformat()
    rows = db.execute(
        """
        SELECT f.id,
               f.fecha,
               r.nombre AS repartidor,
               f.cantidad,
               f.cantidad_20,
               f.cantidad_43,
               f.total_fise,
               f.observaciones,
               f.created_at
        FROM fises_repartidores f
        JOIN repartidores r ON r.id = f.repartidor_id
        WHERE f.fecha = ?
        UNION ALL
        SELECT l.id,
               l.fecha,
               r.nombre AS repartidor,
               l.total_fise_cantidad AS cantidad,
               l.fise_20_cantidad AS cantidad_20,
               l.fise_43_cantidad AS cantidad_43,
               l.total_fise_valor AS total_fise,
               'Liquidacion pedido #' || COALESCE(l.pedido_id, '') AS observaciones,
               l.created_at
        FROM liquidaciones_repartidores l
        JOIN repartidores r ON r.id = l.repartidor_id
        WHERE l.fecha = ? AND l.total_fise_cantidad > 0
        ORDER BY 9 DESC, 1 DESC
        LIMIT 10
        """,
        (selected_iso, selected_iso),
    ).fetchall()
    total_row = db.execute(
        """
        SELECT COALESCE(SUM(cantidad), 0) AS cantidad,
               COALESCE(SUM(cantidad_20), 0) AS cantidad_20,
               COALESCE(SUM(cantidad_43), 0) AS cantidad_43,
               COALESCE(SUM(total), 0) AS total
        FROM (
            SELECT CASE WHEN cantidad_20 > 0 OR cantidad_43 > 0 THEN cantidad_20 + cantidad_43 ELSE cantidad END AS cantidad,
                   cantidad_20,
                   cantidad_43,
                   total_fise AS total
            FROM fises_repartidores
            WHERE fecha = ?
            UNION ALL
            SELECT total_fise_cantidad AS cantidad,
                   fise_20_cantidad AS cantidad_20,
                   fise_43_cantidad AS cantidad_43,
                   total_fise_valor AS total
            FROM liquidaciones_repartidores
            WHERE fecha = ? AND total_fise_cantidad > 0
        )
        """,
        (selected_iso, selected_iso),
    ).fetchone()
    return {
        "cantidad": int(total_row["cantidad"] or 0),
        "cantidad_20": int(total_row["cantidad_20"] or 0),
        "cantidad_43": int(total_row["cantidad_43"] or 0),
        "total": float(total_row["total"] or 0),
        "items": [
            {
                "id": row["id"],
                "fecha": format_date(row["fecha"]),
                "repartidor": row["repartidor"],
                "cantidad": int((row["cantidad_20"] or 0) + (row["cantidad_43"] or 0) or row["cantidad"] or 0),
                "cantidad_20": int(row["cantidad_20"] or 0),
                "cantidad_43": int(row["cantidad_43"] or 0),
                "total_fise": float(row["total_fise"] or 0),
                "observaciones": row["observaciones"] or "",
            }
            for row in rows
        ],
    }


def build_fise_liquidation_report(db, selected_date):
    selected_iso = selected_date.isoformat()
    rows = db.execute(
        """
        SELECT r.id AS repartidor_id,
               r.nombre AS repartidor,
               ? AS fecha,
               COALESCE(liq.cantidad_20, 0) + COALESCE(fp.cantidad_20, 0) AS cantidad_20,
               COALESCE(liq.cantidad_43, 0) + COALESCE(fp.cantidad_43, 0) AS cantidad_43,
               COALESCE(ent.cantidad_20, 0) AS entregado_20,
               COALESCE(ent.cantidad_43, 0) AS entregado_43,
               ent.entregado_at
        FROM repartidores r
        LEFT JOIN (
            SELECT repartidor_id,
                   SUM(fise_20_cantidad) AS cantidad_20,
                   SUM(fise_43_cantidad) AS cantidad_43
            FROM liquidaciones_repartidores
            WHERE fecha = ?
            GROUP BY repartidor_id
        ) liq ON liq.repartidor_id = r.id
        LEFT JOIN (
            SELECT v.repartidor_id,
                   SUM(fp.fise_20_cantidad) AS cantidad_20,
                   SUM(fp.fise_43_cantidad) AS cantidad_43
            FROM fiado_pagos fp
            JOIN ventas v ON v.id = fp.venta_id
            WHERE fp.fecha_pago = ?
            GROUP BY v.repartidor_id
        ) fp ON fp.repartidor_id = r.id
        LEFT JOIN (
            SELECT repartidor_id,
                   SUM(cantidad_20) AS cantidad_20,
                   SUM(cantidad_43) AS cantidad_43,
                   MAX(entregado_at) AS entregado_at
            FROM fise_entregas
            WHERE fecha = ?
            GROUP BY repartidor_id
        ) ent ON ent.repartidor_id = r.id
        WHERE COALESCE(liq.cantidad_20, 0) + COALESCE(liq.cantidad_43, 0)
            + COALESCE(fp.cantidad_20, 0) + COALESCE(fp.cantidad_43, 0) > 0
        ORDER BY r.nombre
        """,
        (selected_iso, selected_iso, selected_iso, selected_iso),
    ).fetchall()
    items = []
    for row in rows:
        total_20 = int(row["cantidad_20"] or 0)
        total_43 = int(row["cantidad_43"] or 0)
        delivered_20 = int(row["entregado_20"] or 0)
        delivered_43 = int(row["entregado_43"] or 0)
        pending_20 = max(total_20 - delivered_20, 0)
        pending_43 = max(total_43 - delivered_43, 0)
        pending_total = pending_20 + pending_43
        pending_value = (pending_20 * FISE_20_VALUE) + (pending_43 * FISE_43_VALUE)
        total_count = total_20 + total_43
        total_value = (total_20 * FISE_20_VALUE) + (total_43 * FISE_43_VALUE)
        items.append(
            {
                "repartidor_id": row["repartidor_id"],
                "repartidor": row["repartidor"],
                "fecha": format_date(row["fecha"]),
                "fecha_iso": row["fecha"],
                "cantidad_20": total_20,
                "cantidad_43": total_43,
                "cantidad_total": total_count,
                "total_fise": float(total_value),
                "pendiente_20": pending_20,
                "pendiente_43": pending_43,
                "pendiente_total": pending_total,
                "pendiente_valor": float(pending_value),
                "estado": "Entregada" if pending_total == 0 else "Pendiente",
                "entregado_at": row["entregado_at"] or "",
            }
        )
    return {
        "items": items,
        "cantidad_20": sum(item["pendiente_20"] for item in items),
        "cantidad_43": sum(item["pendiente_43"] for item in items),
        "cantidad_total": sum(item["pendiente_total"] for item in items),
        "total_fise": sum(item["pendiente_valor"] for item in items),
    }


def build_loans_report(db, selected_date):
    selected_iso = selected_date.isoformat()
    row = db.execute(
        """
        SELECT COALESCE(SUM(CASE WHEN tipo_cliente = 'cliente' THEN cantidad - devueltos ELSE 0 END), 0) AS clientes,
               COALESCE(SUM(CASE WHEN tipo_cliente = 'mayorista' THEN cantidad - devueltos ELSE 0 END), 0) AS mayoristas
        FROM prestamos
        WHERE fecha <= ?
        """,
        (selected_iso,),
    ).fetchone()
    latest = [
        {
            "fecha": format_date(item["fecha"]),
            "cliente": item["cliente"],
            "tipo_cliente": item["tipo_cliente"],
            "tipo_balon": item["tipo_balon"],
            "cantidad": int(item["cantidad"]),
            "pendiente": int(item["cantidad"] - item["devueltos"]),
        }
        for item in db.execute(
            """
            SELECT fecha, cliente, tipo_cliente, tipo_balon, cantidad, devueltos
            FROM prestamos
            WHERE cantidad > devueltos
            ORDER BY fecha DESC, id DESC
            LIMIT 8
            """
        ).fetchall()
    ]
    return {
        "clientes": int(row["clientes"] or 0),
        "mayoristas": int(row["mayoristas"] or 0),
        "latest": latest,
    }


def build_orders_report(db, selected_date):
    selected_iso = selected_date.isoformat()
    rows = db.execute(
        """
        SELECT p.id,
               p.fecha,
               p.cliente,
               p.telefono,
               p.direccion,
               p.cantidad,
               p.producto,
               p.tipo_valvula,
               p.costo_producto,
               p.precio_venta,
               p.ganancia_estimada,
               p.items_resumen,
               p.estado,
               p.observaciones,
               p.despacho_observaciones,
               p.repartidor_id,
               p.venta_id,
               COALESCE(r.nombre, '') AS repartidor,
               COALESCE(v.total_venta, 0) AS total_venta,
               p.created_at
        FROM pedidos p
        LEFT JOIN repartidores r ON r.id = p.repartidor_id
        LEFT JOIN ventas v ON v.id = p.venta_id
        WHERE p.fecha = ?
        ORDER BY CASE p.estado
            WHEN 'pendiente' THEN 1
            WHEN 'en_ruta' THEN 2
            WHEN 'entregado' THEN 3
            WHEN 'liquidado' THEN 4
            WHEN 'anulado' THEN 5
            ELSE 9
        END,
        p.created_at DESC,
        p.id DESC
        """,
        (selected_iso,),
    ).fetchall()
    latest = []
    for row in rows:
        items = get_order_items(db, row)
        totals = item_totals(items)
        latest.append(
            {
            "id": row["id"],
            "fecha": format_date(row["fecha"]),
            "fecha_iso": row["fecha"],
            "cliente": row["cliente"],
            "telefono": row["telefono"] or "",
            "direccion": row["direccion"],
            "cantidad": int(totals["cantidad"] or row["cantidad"] or 0),
            "producto": row["producto"] or "",
            "tipo_valvula": row["tipo_valvula"] or "",
            "costo_producto": float(row["costo_producto"] or 0),
            "precio_venta": float(row["precio_venta"] or 0),
            "ganancia_estimada": float(totals["ganancia"] or row["ganancia_estimada"] or 0),
            "estado": row["estado"],
            "estado_label": order_state_label(row["estado"]),
            "repartidor_id": row["repartidor_id"],
            "venta_id": row["venta_id"],
            "repartidor": row["repartidor"] or "",
            "total_venta": float(row["total_venta"] or totals["total_venta"] or 0),
            "observaciones": row["observaciones"] or "",
            "despacho_observaciones": row["despacho_observaciones"] or "",
            "items": items,
            "items_resumen": row["items_resumen"] or summarize_items(items),
        }
        )
    counts = {state: 0 for state in ORDER_STATES}
    for item in latest:
        counts[item["estado"]] = counts.get(item["estado"], 0) + 1

    return {
        "counts": counts,
        "total": len(latest),
        "latest": latest,
        "pending": [item for item in latest if item["estado"] == "pendiente"],
        "on_route": [item for item in latest if item["estado"] == "en_ruta"],
        "delivered": [item for item in latest if item["estado"] == "entregado"],
    }


def build_product_summary(db, selected_date):
    selected_iso = selected_date.isoformat()
    product_rows = db.execute(
        """
        SELECT COALESCE(vi.producto, 'SIN PRODUCTO') AS producto,
               COALESCE(SUM(vi.cantidad), 0) AS cantidad,
               COALESCE(SUM(vi.total_venta), 0) AS ventas,
               COALESCE(SUM(vi.ganancia), 0) AS ganancia
        FROM venta_items vi
        JOIN ventas v ON v.id = vi.venta_id
        WHERE v.fecha = ?
        GROUP BY COALESCE(vi.producto, 'SIN PRODUCTO')
        ORDER BY ventas DESC
        """,
        (selected_iso,),
    ).fetchall()
    valve_rows = db.execute(
        """
        SELECT COALESCE(NULLIF(vi.tipo_valvula, ''), 'SIN VALVULA') AS tipo_valvula,
               COALESCE(SUM(vi.cantidad), 0) AS cantidad,
               COALESCE(SUM(vi.total_venta), 0) AS ventas
        FROM venta_items vi
        JOIN ventas v ON v.id = vi.venta_id
        WHERE v.fecha = ? AND vi.producto LIKE '%GAS%'
        GROUP BY COALESCE(NULLIF(vi.tipo_valvula, ''), 'SIN VALVULA')
        ORDER BY ventas DESC
        """,
        (selected_iso,),
    ).fetchall()
    return {
        "products": [
            {
                "producto": row["producto"],
                "cantidad": int(row["cantidad"] or 0),
                "ventas": float(row["ventas"] or 0),
                "ganancia": float(row["ganancia"] or 0),
            }
            for row in product_rows
        ],
        "valves": [
            {
                "tipo_valvula": row["tipo_valvula"],
                "cantidad": int(row["cantidad"] or 0),
                "ventas": float(row["ventas"] or 0),
            }
            for row in valve_rows
        ],
    }


def build_movements(db, selected_date):
    rows = db.execute(
        """
        SELECT v.fecha,
               v.id AS source_id,
               'venta' AS source_type,
               'Venta' AS concepto,
               'Ingreso' AS tipo,
               'Ventas' AS categoria,
               COALESCE(r.nombre, v.repartidor, '-') AS repartidor,
               v.total_venta AS amount,
               v.ganancia AS profit,
               'Producto: ' || COALESCE(NULLIF(v.items_resumen, ''), v.producto, 'Sin producto') ||
                 CASE
                   WHEN COALESCE(v.tipo_valvula, '') != '' THEN ' | Valvula: ' || v.tipo_valvula
                   ELSE ''
                 END ||
                 ' | ' ||
               'Efec: ' || printf('S/ %.2f', v.pago_efectivo) ||
                 ' | Yape: ' || printf('S/ %.2f', v.pago_yape) ||
                 ' | Yape Marcos: ' || printf('S/ %.2f', v.pago_yape_marcos) ||
                 ' | Plin: ' || printf('S/ %.2f', v.pago_plin) ||
                 ' | FISE: ' || printf('S/ %.2f', v.pago_fise) ||
                 ' | Fiado: ' || printf('S/ %.2f', v.pago_fiado) ||
                 ' | Vuelto Yape: ' || printf('S/ %.2f', v.pago_vuelto_yape) ||
                 CASE
                   WHEN COALESCE(v.observaciones, '') != '' THEN ' | ' || v.observaciones
                   ELSE ''
                 END AS observaciones,
               v.created_at
        FROM ventas v
        LEFT JOIN repartidores r ON r.id = v.repartidor_id
        WHERE v.fecha = ?
        UNION ALL
        SELECT p.fecha,
               p.id AS source_id,
               'pedido' AS source_type,
               'Pedido #' || p.id || ' - ' || p.cliente AS concepto,
               CASE
                   WHEN p.estado = 'pendiente' THEN 'Pedido'
                   WHEN p.estado = 'en_ruta' THEN 'Despacho'
                   WHEN p.estado = 'entregado' THEN 'Entrega'
                   ELSE 'Pedido'
               END AS tipo,
               p.estado AS categoria,
               COALESCE(r.nombre, '-') AS repartidor,
               0 AS amount,
               0 AS profit,
               'Producto: ' || COALESCE(NULLIF(p.items_resumen, ''), p.producto, 'Sin producto') ||
                 CASE
                   WHEN COALESCE(p.tipo_valvula, '') != '' THEN ' | Valvula: ' || p.tipo_valvula
                   ELSE ''
                 END ||
                 ' | Estado: ' || p.estado ||
                 CASE
                   WHEN COALESCE(p.direccion, '') != '' THEN ' | ' || p.direccion
                   ELSE ''
                 END AS observaciones,
               p.updated_at AS created_at
        FROM pedidos p
        LEFT JOIN repartidores r ON r.id = p.repartidor_id
        WHERE p.fecha = ? AND p.estado NOT IN ('liquidado', 'anulado')
        UNION ALL
        SELECT fecha,
               id AS source_id,
               'gasto' AS source_type,
               concepto,
               'Egreso' AS tipo,
               categoria,
               '-' AS repartidor,
               -monto AS amount,
               0 AS profit,
               COALESCE(observaciones, '') AS observaciones,
               created_at
        FROM gastos
        WHERE fecha = ?
        UNION ALL
        SELECT l.fecha,
               l.id AS source_id,
               'liquidacion' AS source_type,
               'Liquidacion de repartidor' AS concepto,
               'Caja' AS tipo,
               'Repartidores' AS categoria,
               r.nombre AS repartidor,
               l.entregado AS amount,
               0 AS profit,
               'Debe: ' || printf('S/ %.2f', l.debe_entregar) ||
                 ' | Diferencia: ' || printf('S/ %.2f', l.diferencia) ||
                 CASE
                   WHEN COALESCE(l.observaciones, '') != '' THEN ' | ' || l.observaciones
                   ELSE ''
                 END AS observaciones,
               l.created_at
        FROM liquidaciones_repartidores l
        JOIN repartidores r ON r.id = l.repartidor_id
        WHERE l.fecha = ?
        UNION ALL
        SELECT f.fecha,
               f.id AS source_id,
               'fise' AS source_type,
               'FISE reportado' AS concepto,
               'FISE' AS tipo,
               'Repartidores' AS categoria,
               r.nombre AS repartidor,
               f.total_fise AS amount,
               0 AS profit,
               'Cantidad: ' || f.cantidad ||
                 CASE
                   WHEN COALESCE(f.observaciones, '') != '' THEN ' | ' || f.observaciones
                   ELSE ''
                 END AS observaciones,
               f.created_at
        FROM fises_repartidores f
        JOIN repartidores r ON r.id = f.repartidor_id
        WHERE f.fecha = ?
        UNION ALL
        SELECT fecha,
               id AS source_id,
               'prestamo' AS source_type,
               'Prestamo de balon' AS concepto,
               'Inventario' AS tipo,
               tipo_cliente AS categoria,
               cliente AS repartidor,
               0 AS amount,
               0 AS profit,
               tipo_balon || ' x ' || cantidad || ' pendiente: ' || (cantidad - devueltos) AS observaciones,
               created_at
        FROM prestamos
        WHERE fecha = ?
        ORDER BY created_at DESC
        LIMIT 24
        """,
        (
            selected_date.isoformat(),
            selected_date.isoformat(),
            selected_date.isoformat(),
            selected_date.isoformat(),
            selected_date.isoformat(),
            selected_date.isoformat(),
        ),
    ).fetchall()

    return [
        {
            "date": format_date(row["fecha"]),
            "id": row["source_id"],
            "source_type": row["source_type"],
            "concept": row["concepto"],
            "type": row["tipo"],
            "category": row["categoria"],
            "driver": row["repartidor"] or "-",
            "amount": float(row["amount"] or 0),
            "profit": float(row["profit"] or 0),
            "note": row["observaciones"] or "-",
        }
        for row in rows
    ]


def build_driver_summary(db, selected_date):
    rows = db.execute(
        """
        SELECT r.id,
               r.nombre,
               COALESCE(v.total_vendido, 0) AS total_vendido,
               COALESCE(v.total_cobrado, 0) AS total_cobrado,
               COALESCE(v.total_pendiente, 0) AS total_pendiente,
               COALESCE(v.ganancia, 0) AS ganancia,
               COALESCE(v.debe_entregar, 0) AS debe_entregar,
               COALESCE(v.vuelto_yape, 0) AS vuelto_yape,
               COALESCE(v.fise_20_cantidad, 0) AS fise_20_cantidad,
               COALESCE(v.fise_43_cantidad, 0) AS fise_43_cantidad,
               COALESCE(v.total_fise_valor, 0) AS total_fise_valor,
               COALESCE(l.entregado, 0) + COALESCE(p.pagos_legacy, 0) AS entregado
        FROM repartidores r
        LEFT JOIN (
            SELECT v.repartidor_id,
                   SUM(total_venta) AS total_vendido,
                   SUM(pago_efectivo + pago_yape + pago_yape_marcos + pago_plin + pago_fise) AS total_cobrado,
                   SUM(pago_fiado) AS total_pendiente,
                   SUM(ganancia) AS ganancia,
                   SUM(pago_efectivo) AS debe_entregar,
                   SUM(pago_vuelto_yape) AS vuelto_yape,
                   SUM(COALESCE(lr.fise_20_cantidad, 0)) AS fise_20_cantidad,
                   SUM(COALESCE(lr.fise_43_cantidad, 0)) AS fise_43_cantidad,
                   SUM(COALESCE(lr.total_fise_valor, 0)) AS total_fise_valor
            FROM ventas v
            LEFT JOIN liquidaciones_repartidores lr ON lr.venta_id = v.id
            WHERE v.fecha = ?
            GROUP BY v.repartidor_id
        ) v ON v.repartidor_id = r.id
        LEFT JOIN (
            SELECT repartidor_id,
                   SUM(entregado) AS entregado
            FROM liquidaciones_repartidores
            WHERE fecha = ?
            GROUP BY repartidor_id
        ) l ON l.repartidor_id = r.id
        LEFT JOIN (
            SELECT pr.repartidor_id,
                   SUM(pr.monto) AS pagos_legacy
            FROM pagos_repartidores pr
            WHERE pr.fecha = ?
              AND NOT EXISTS (
                  SELECT 1
                  FROM liquidaciones_repartidores lr
                  WHERE lr.fecha = pr.fecha
                    AND lr.repartidor_id = pr.repartidor_id
              )
            GROUP BY pr.repartidor_id
        ) p ON p.repartidor_id = r.id
        WHERE COALESCE(v.total_vendido, 0) > 0
           OR COALESCE(l.entregado, 0) > 0
           OR COALESCE(p.pagos_legacy, 0) > 0
        ORDER BY r.nombre
        """,
        (selected_date.isoformat(), selected_date.isoformat(), selected_date.isoformat()),
    ).fetchall()

    summary = []
    for row in rows:
        debe_entregar = float(row["debe_entregar"] or 0)
        entregado = float(row["entregado"] or 0)
        diferencia = entregado - debe_entregar
        summary.append(
            {
                "id": row["id"],
                "driver": row["nombre"],
                "total_vendido": float(row["total_vendido"] or 0),
                "total_cobrado": float(row["total_cobrado"] or 0),
                "total_pendiente": float(row["total_pendiente"] or 0),
                "debe_entregar": debe_entregar,
                "dinero_entregado": entregado,
                "dinero_pendiente": max(debe_entregar - entregado, 0),
                "sobrante": max(diferencia, 0),
                "diferencia": diferencia,
                "ganancia": float(row["ganancia"] or 0),
                "vuelto_yape": float(row["vuelto_yape"] or 0),
                "fise_20_cantidad": int(row["fise_20_cantidad"] or 0),
                "fise_43_cantidad": int(row["fise_43_cantidad"] or 0),
                "total_fise_cantidad": int(row["fise_20_cantidad"] or 0) + int(row["fise_43_cantidad"] or 0),
                "total_fise_valor": float(row["total_fise_valor"] or 0),
            }
        )
    return summary


def build_account_summary(db, selected_date):
    selected_iso = selected_date.isoformat()
    rows = db.execute(
        """
        SELECT c.id,
               c.codigo,
               c.nombre,
               COALESCE(s.saldo_inicial, 0) AS saldo_inicial,
               COALESCE(m.ingresos, 0) AS ingresos,
               COALESCE(m.egresos, 0) AS egresos
        FROM cuentas_bancarias c
        LEFT JOIN saldos_diarios s
               ON s.cuenta_id = c.id
              AND s.fecha = ?
        LEFT JOIN (
            SELECT cuenta_id,
                   SUM(CASE WHEN tipo = 'ingreso' THEN monto ELSE 0 END) AS ingresos,
                   SUM(CASE WHEN tipo = 'egreso' THEN monto ELSE 0 END) AS egresos
            FROM movimientos_cuentas
            WHERE fecha = ?
            GROUP BY cuenta_id
        ) m ON m.cuenta_id = c.id
        WHERE c.activo = 1
        ORDER BY CASE c.codigo
            WHEN 'bcp' THEN 1
            WHEN 'interbank' THEN 2
            WHEN 'fise' THEN 3
            WHEN 'caja' THEN 4
            WHEN 'yape' THEN 5
            WHEN 'plin' THEN 6
            ELSE 99
        END
        """,
        (selected_iso, selected_iso),
    ).fetchall()

    accounts = []
    total_initial = 0
    total_income = 0
    total_expense = 0
    for row in rows:
        initial = float(row["saldo_inicial"] or 0)
        income = float(row["ingresos"] or 0)
        expense = float(row["egresos"] or 0)
        movements = income - expense
        current = initial + movements
        total_initial += initial
        total_income += income
        total_expense += expense
        accounts.append(
            {
                "codigo": row["codigo"],
                "nombre": row["nombre"],
                "saldo_inicial": initial,
                "ingresos": income,
                "egresos": expense,
                "movimientos": movements,
                "saldo_actual": current,
            }
        )

    return {
        "accounts": accounts,
        "initial_values": {item["codigo"]: item["saldo_inicial"] for item in accounts},
        "saldo_inicial_total": total_initial,
        "ingresos": total_income,
        "egresos": total_expense,
        "movimientos": total_income - total_expense,
        "saldo_total": total_initial + total_income - total_expense,
    }


def build_liquidation_history(db, selected_date):
    rows = db.execute(
        """
        SELECT l.fecha,
               l.id,
               l.pedido_id,
               l.venta_id,
               r.nombre AS repartidor,
               p.cliente,
               l.debe_entregar,
               l.entregado,
               l.diferencia,
               l.vuelto_yape,
               l.fise_20_cantidad,
               l.fise_43_cantidad,
               l.total_fise_cantidad,
               l.total_fise_valor,
               l.observaciones
        FROM liquidaciones_repartidores l
        JOIN repartidores r ON r.id = l.repartidor_id
        LEFT JOIN pedidos p ON p.id = l.pedido_id
        WHERE l.fecha = ?
        ORDER BY l.created_at DESC, l.id DESC
        LIMIT 8
        """,
        (selected_date.isoformat(),),
    ).fetchall()
    return [
        {
            "fecha": format_date(row["fecha"]),
            "id": row["id"],
            "pedido_id": row["pedido_id"],
            "venta_id": row["venta_id"],
            "repartidor": row["repartidor"],
            "cliente": row["cliente"] or "",
            "debe_entregar": float(row["debe_entregar"] or 0),
            "entregado": float(row["entregado"] or 0),
            "diferencia": float(row["diferencia"] or 0),
            "vuelto_yape": float(row["vuelto_yape"] or 0),
            "fise_20_cantidad": int(row["fise_20_cantidad"] or 0),
            "fise_43_cantidad": int(row["fise_43_cantidad"] or 0),
            "total_fise_cantidad": int(row["total_fise_cantidad"] or 0),
            "total_fise_valor": float(row["total_fise_valor"] or 0),
            "observaciones": row["observaciones"] or "",
        }
        for row in rows
    ]


def build_credit_clients_report(db):
    rows = db.execute(
        """
        SELECT v.id,
               v.fecha,
               v.cliente,
               COALESCE(p.direccion, '') AS direccion,
               COALESCE(p.telefono, '') AS telefono,
               p.id AS pedido_id,
               COALESCE(r.nombre, v.repartidor, '') AS repartidor,
               v.repartidor_id,
               v.pago_fiado,
               COALESCE(pg.pagado, 0) AS pagado,
               COALESCE(pg.historial, '') AS historial
        FROM ventas v
        LEFT JOIN pedidos p ON p.id = v.pedido_id
        LEFT JOIN repartidores r ON r.id = v.repartidor_id
        LEFT JOIN (
            SELECT venta_id,
                   SUM(total_pagado) AS pagado,
                   GROUP_CONCAT(fecha_pago || ' ' || metodo_pago || ' S/ ' || printf('%.2f', total_pagado), ' | ') AS historial
            FROM fiado_pagos
            GROUP BY venta_id
        ) pg ON pg.venta_id = v.id
        WHERE v.pago_fiado > 0
        ORDER BY v.fecha DESC, v.id DESC
        LIMIT 200
        """
    ).fetchall()
    today = date.today()
    return [
        {
            "id": row["id"],
            "pedido_id": row["pedido_id"],
            "cliente": row["cliente"] or "",
            "direccion": row["direccion"] or "",
            "telefono": row["telefono"] or "",
            "fecha": format_date(row["fecha"]),
            "fecha_iso": row["fecha"],
            "repartidor": row["repartidor"] or "",
            "repartidor_id": row["repartidor_id"],
            "monto_original": float(row["pago_fiado"] or 0),
            "pagado": float(row["pagado"] or 0),
            "monto": max(float(row["pago_fiado"] or 0) - float(row["pagado"] or 0), 0),
            "dias_atraso": max((today - parse_iso_date(row["fecha"], today)).days, 0),
            "estado": "Fiado liquidado" if float(row["pagado"] or 0) >= float(row["pago_fiado"] or 0) else "Fiado pendiente",
            "historial": row["historial"] or "",
        }
        for row in rows
    ]


def build_account_movements(db, selected_date):
    rows = db.execute(
        """
        SELECT m.fecha,
               c.nombre AS cuenta,
               m.tipo,
               m.monto,
               m.referencia
        FROM movimientos_cuentas m
        JOIN cuentas_bancarias c ON c.id = m.cuenta_id
        WHERE m.fecha = ?
        ORDER BY m.created_at DESC, m.id DESC
        LIMIT 10
        """,
        (selected_date.isoformat(),),
    ).fetchall()
    return [
        {
            "fecha": format_date(row["fecha"]),
            "cuenta": row["cuenta"],
            "tipo": row["tipo"],
            "monto": float(row["monto"] or 0),
            "referencia": row["referencia"] or "",
        }
        for row in rows
    ]


def get_drivers(db):
    return [
        {"id": row["id"], "nombre": row["nombre"], "telefono": row["telefono"] or ""}
        for row in db.execute("SELECT id, nombre, telefono FROM repartidores WHERE activo = 1 ORDER BY nombre").fetchall()
    ]


def build_management_data(db, selected_date):
    selected_iso = selected_date.isoformat()
    ventas = [
        {
            "id": row["id"],
            "fecha": row["fecha"],
            "cliente": row["cliente"] or "",
            "repartidor": row["repartidor"] or "",
            "repartidor_id": row["repartidor_id"],
            "cantidad": int(row["cantidad"] or 0),
            "producto": row["producto"] or "",
            "tipo_valvula": row["tipo_valvula"] or "",
            "costo_balon": float(row["costo_balon"] or 0),
            "precio_venta": float(row["precio_venta"] or 0),
            "total_venta": float(row["total_venta"] or 0),
            "pago_efectivo": float(row["pago_efectivo"] or 0),
            "pago_yape": float(row["pago_yape"] or 0),
            "pago_yape_marcos": float(row["pago_yape_marcos"] or 0),
            "pago_plin": float(row["pago_plin"] or 0),
            "pago_fise": float(row["pago_fise"] or 0),
            "pago_fiado": float(row["pago_fiado"] or 0),
            "pago_vuelto_yape": float(row["pago_vuelto_yape"] or 0),
            "dinero_entregado": float(row["dinero_entregado"] or 0),
            "pedido_id": row["pedido_id"],
            "observaciones": row["observaciones"] or "",
        }
        for row in db.execute(
            """
            SELECT *
            FROM ventas
            WHERE fecha = ?
            ORDER BY id DESC
            LIMIT 80
            """,
            (selected_iso,),
        ).fetchall()
    ]
    gastos = [
        {
            "id": row["id"],
            "fecha": row["fecha"],
            "concepto": row["concepto"],
            "categoria": row["categoria"],
            "monto": float(row["monto"] or 0),
            "observaciones": row["observaciones"] or "",
        }
        for row in db.execute(
            """
            SELECT id, fecha, concepto, categoria, monto, observaciones
            FROM gastos
            WHERE fecha = ?
            ORDER BY id DESC
            LIMIT 80
            """,
            (selected_iso,),
        ).fetchall()
    ]
    liquidaciones = [
        {
            "id": row["id"],
            "fecha": row["fecha"],
            "repartidor_id": row["repartidor_id"],
            "repartidor": row["repartidor"] or "",
            "pedido_id": row["pedido_id"],
            "venta_id": row["venta_id"],
            "debe_entregar": float(row["debe_entregar"] or 0),
            "entregado": float(row["entregado"] or 0),
            "diferencia": float(row["diferencia"] or 0),
            "vuelto_yape": float(row["vuelto_yape"] or 0),
            "fise_20_cantidad": int(row["fise_20_cantidad"] or 0),
            "fise_43_cantidad": int(row["fise_43_cantidad"] or 0),
            "total_fise_cantidad": int(row["total_fise_cantidad"] or 0),
            "total_fise_valor": float(row["total_fise_valor"] or 0),
            "observaciones": row["observaciones"] or "",
        }
        for row in db.execute(
            """
            SELECT l.*, r.nombre AS repartidor
            FROM liquidaciones_repartidores l
            LEFT JOIN repartidores r ON r.id = l.repartidor_id
            WHERE l.fecha = ?
            ORDER BY l.id DESC
            LIMIT 80
            """,
            (selected_iso,),
        ).fetchall()
    ]
    return {
        "ventas": ventas,
        "gastos": gastos,
        "liquidaciones": liquidaciones,
        "repartidores": get_drivers(db),
    }


def dashboard_payload(selected_date=None):
    selected_date = selected_date or selected_date_from_request()
    selected_iso = selected_date.isoformat()
    with get_connection() as db:
        month_start = month_start_iso(selected_date)
        inventory = db.execute("SELECT * FROM inventario WHERE id = 1").fetchone()
        water_inventory = db.execute("SELECT * FROM inventario_agua WHERE id = 1").fetchone()

        income_day = one_value(db, "SELECT COALESCE(SUM(total_venta), 0) FROM ventas WHERE fecha = ?", (selected_iso,))
        expense_day = one_value(db, "SELECT COALESCE(SUM(monto), 0) FROM gastos WHERE fecha = ?", (selected_iso,))
        profit_day = one_value(db, "SELECT COALESCE(SUM(ganancia), 0) FROM ventas WHERE fecha = ?", (selected_iso,))
        sales_today = one_value(db, "SELECT COUNT(*) FROM ventas WHERE fecha = ?", (selected_iso,))
        income_month = one_value(
            db,
            "SELECT COALESCE(SUM(total_venta), 0) FROM ventas WHERE fecha >= ? AND fecha <= ?",
            (month_start, selected_iso),
        )
        expense_month = one_value(
            db,
            "SELECT COALESCE(SUM(monto), 0) FROM gastos WHERE fecha >= ? AND fecha <= ?",
            (month_start, selected_iso),
        )
        gross_profit_month = one_value(
            db,
            "SELECT COALESCE(SUM(ganancia), 0) FROM ventas WHERE fecha >= ? AND fecha <= ?",
            (month_start, selected_iso),
        )
        sales_count = one_value(
            db,
            "SELECT COUNT(*) FROM ventas WHERE fecha >= ? AND fecha <= ?",
            (month_start, selected_iso),
        )
        clients_count = one_value(
            db,
            "SELECT COUNT(DISTINCT NULLIF(TRIM(cliente), '')) FROM ventas WHERE fecha >= ? AND fecha <= ?",
            (month_start, selected_iso),
        )
        expense_categories, expense_total = build_expense_categories(db, selected_date)
        loans = build_loans_report(db, selected_date)
        account_summary = build_account_summary(db, selected_date)
        orders = build_orders_report(db, selected_date)
        product_summary = build_product_summary(db, selected_date)

        return {
            "selected_date": selected_iso,
            "today_iso": today_iso(),
            "date_label": date_label(selected_date),
            "daily_price": get_daily_price(db, selected_date),
            "price_history": build_price_history(db),
            "payment_summary": build_payment_summary(db, selected_date),
            "account_summary": account_summary,
            "orders": orders,
            "product_summary": product_summary,
            "liquidation_history": build_liquidation_history(db, selected_date),
            "account_movements": build_account_movements(db, selected_date),
            "stock_control": build_stock_control(db, selected_date, inventory),
            "inventory_movements": build_inventory_movements(db, selected_date),
            "water_inventory": build_water_inventory_report(db, selected_date, water_inventory),
            "fise_report": build_fise_report(db, selected_date),
            "fise_liquidation": build_fise_liquidation_report(db, selected_date),
            "credit_clients": build_credit_clients_report(db),
            "loans": loans,
            "metrics": {
                "income_today": float(income_day),
                "expense_today": float(expense_day),
                "profit_today": float(profit_day),
                "balance_today": float(account_summary["saldo_total"]),
                "stock": int(inventory["llenos"]),
                "sales_today": int(sales_today),
                "orders_pending": int(orders["counts"].get("pendiente", 0)),
                "orders_delivered": int(orders["counts"].get("entregado", 0) + orders["counts"].get("liquidado", 0)),
                "loaned_total": int(loans["clientes"] + loans["mayoristas"]),
            },
            "inventory": {
                "llenos": int(inventory["llenos"]),
                "vacios": int(inventory["vacios"]),
                "prestados_clientes": int(inventory["prestados_clientes"]),
                "prestados_mayoristas": int(inventory["prestados_mayoristas"]),
                "entradas_mes": int(inventory["entradas_mes"]),
                "salidas_mes": int(inventory["salidas_mes"]),
            },
            "movements": build_movements(db, selected_date),
            "driver_summary": build_driver_summary(db, selected_date),
            "sales_chart": build_sales_chart(db, selected_date),
            "expense_categories": expense_categories,
            "expense_total": float(expense_total),
            "drivers": get_drivers(db),
            "management": build_management_data(db, selected_date),
            "month_summary": {
                "income": float(income_month),
                "expense": float(expense_month),
                "profit": float(gross_profit_month - expense_month),
                "gross_profit": float(gross_profit_month),
                "sales_count": int(sales_count),
                "clients_count": int(clients_count),
            },
        }


def redirect_to_dashboard(fecha, anchor="formularios"):
    return redirect(url_for("dashboard", fecha=fecha) + f"#{anchor}")


def is_logged_in():
    return session.get("logged_in") is True


@app.before_request
def require_login():
    public_endpoints = {"login", "static"}
    if request.endpoint in public_endpoints:
        return None
    if is_logged_in():
        return None
    if request.path.startswith("/static/"):
        return None
    return redirect(url_for("login", next=request.full_path if request.query_string else request.path))


@app.route("/login", methods=["GET", "POST"])
def login():
    if request.method == "POST":
        usuario = text_from_form("usuario")
        password = text_from_form("password")
        if usuario == ADMIN_USER and check_password_hash(ADMIN_PASSWORD_HASH, password):
            session.clear()
            session["logged_in"] = True
            session["usuario"] = usuario
            flash("Sesion iniciada correctamente.", "success")
            next_url = request.args.get("next") or url_for("dashboard")
            return redirect(next_url)
        flash("Usuario o contrasena incorrectos.", "danger")
    return render_template("login.html")


@app.route("/logout", methods=["POST"])
def logout():
    session.clear()
    flash("Sesion cerrada correctamente.", "success")
    return redirect(url_for("login"))


@app.route("/")
def dashboard():
    selected_date = selected_date_from_request()
    data = dashboard_payload(selected_date)
    return render_template("dashboard.html", dashboard_data=data, **data)


@app.route("/api/dashboard")
def api_dashboard():
    return jsonify(dashboard_payload(selected_date_from_request()))


def column_letter(index):
    letters = ""
    while index:
        index, remainder = divmod(index - 1, 26)
        letters = chr(65 + remainder) + letters
    return letters


def xlsx_cell(row_index, column_index, value):
    ref = f"{column_letter(column_index)}{row_index}"
    if value is None:
        value = ""
    if isinstance(value, (int, float)):
        return f'<c r="{ref}"><v>{value}</v></c>'
    text = escape(str(value))
    return f'<c r="{ref}" t="inlineStr"><is><t>{text}</t></is></c>'


def make_xlsx(sheet_name, headers, rows):
    output = io.BytesIO()
    all_rows = [headers] + rows
    sheet_rows = []
    for row_index, row in enumerate(all_rows, start=1):
        cells = "".join(xlsx_cell(row_index, column_index, value) for column_index, value in enumerate(row, start=1))
        sheet_rows.append(f'<row r="{row_index}">{cells}</row>')

    worksheet = f"""<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main">
  <sheetData>{''.join(sheet_rows)}</sheetData>
</worksheet>"""
    workbook = f"""<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<workbook xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main"
          xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships">
  <sheets><sheet name="{escape(sheet_name[:31])}" sheetId="1" r:id="rId1"/></sheets>
</workbook>"""
    content_types = """<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Types xmlns="http://schemas.openxmlformats.org/package/2006/content-types">
  <Default Extension="rels" ContentType="application/vnd.openxmlformats-package.relationships+xml"/>
  <Default Extension="xml" ContentType="application/xml"/>
  <Override PartName="/xl/workbook.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml"/>
  <Override PartName="/xl/worksheets/sheet1.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml"/>
</Types>"""
    root_rels = """<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">
  <Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument" Target="xl/workbook.xml"/>
</Relationships>"""
    workbook_rels = """<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">
  <Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet" Target="worksheets/sheet1.xml"/>
</Relationships>"""

    with zipfile.ZipFile(output, "w", zipfile.ZIP_DEFLATED) as xlsx:
        xlsx.writestr("[Content_Types].xml", content_types)
        xlsx.writestr("_rels/.rels", root_rels)
        xlsx.writestr("xl/workbook.xml", workbook)
        xlsx.writestr("xl/_rels/workbook.xml.rels", workbook_rels)
        xlsx.writestr("xl/worksheets/sheet1.xml", worksheet)
    output.seek(0)
    return output


def export_rows(db, modulo, selected_date):
    selected_iso = selected_date.isoformat()
    if modulo == "pedidos":
        rows = db.execute(
            """
            SELECT p.id, p.fecha, p.cliente, p.telefono, p.direccion, p.cantidad,
                   p.producto, p.tipo_valvula, p.costo_producto, p.precio_venta,
                   p.ganancia_estimada, p.items_resumen, p.estado, COALESCE(r.nombre, '') AS repartidor,
                   COALESCE(p.observaciones, '') AS observaciones
            FROM pedidos p
            LEFT JOIN repartidores r ON r.id = p.repartidor_id
            WHERE p.fecha = ?
            ORDER BY p.id
            """,
            (selected_iso,),
        ).fetchall()
        return [
            "ID", "Fecha", "Cliente", "Telefono", "Direccion", "Cantidad", "Producto", "Valvula",
            "Costo", "Precio", "Ganancia", "Items", "Estado", "Repartidor", "Observaciones"
        ], [
            [
                row["id"], row["fecha"], row["cliente"], row["telefono"], row["direccion"],
                row["cantidad"], row["producto"], row["tipo_valvula"], row["costo_producto"],
                row["precio_venta"], row["ganancia_estimada"], row["items_resumen"], row["estado"], row["repartidor"],
                row["observaciones"],
            ]
            for row in rows
        ]

    if modulo == "ventas":
        rows = db.execute(
            """
            SELECT id, fecha, cliente, repartidor, repartidor_id, cantidad, producto, tipo_valvula, items_resumen, costo_balon, precio_venta,
                   total_costo, total_venta, ganancia, pago_efectivo, pago_yape,
                   pago_yape_marcos, pago_plin, pago_fise, pago_fiado, pago_vuelto_yape
            FROM ventas
            WHERE fecha = ?
            ORDER BY id
            """,
            (selected_iso,),
        ).fetchall()
        return [
            "ID", "Fecha", "Cliente", "Repartidor", "Repartidor ID", "Cantidad", "Producto", "Valvula", "Items", "Costo", "Precio", "Total costo",
            "Total venta", "Ganancia", "Efectivo recibido", "Yape", "Yape Marcos", "Plin", "FISE", "Fiado", "Vuelto Yape"
        ], [list(row) for row in rows]

    if modulo == "gastos":
        rows = db.execute(
            """
            SELECT id, fecha, concepto, categoria, monto, observaciones
            FROM gastos
            WHERE fecha = ?
            ORDER BY id
            """,
            (selected_iso,),
        ).fetchall()
        return ["ID", "Fecha", "Concepto", "Categoria", "Monto", "Observaciones"], [list(row) for row in rows]

    if modulo == "inventario":
        inventory = db.execute("SELECT * FROM inventario WHERE id = 1").fetchone()
        water = db.execute("SELECT * FROM inventario_agua WHERE id = 1").fetchone()
        rows = [
            [
                "Inventario gas",
                selected_iso,
                inventory["llenos"],
                inventory["vacios"],
                inventory["prestados_clientes"],
                inventory["prestados_mayoristas"],
                inventory["entradas_mes"],
                inventory["salidas_mes"],
                "",
            ],
            [
                "Inventario agua",
                selected_iso,
                water["llenos"],
                water["vacios"],
                0,
                0,
                water["entradas_mes"],
                water["salidas_mes"],
                "",
            ]
        ]
        movements = db.execute(
            """
            SELECT tipo, fecha, cantidad_llenos, cantidad_vacios,
                   cantidad_prestados_clientes, cantidad_prestados_mayoristas, 0, 0, referencia
            FROM movimientos_inventario
            WHERE fecha = ?
            ORDER BY id
            """,
            (selected_iso,),
        ).fetchall()
        rows.extend([list(row) for row in movements])
        water_movements = db.execute(
            """
            SELECT tipo, fecha, cantidad_llenos, cantidad_vacios, 0, 0, 0, 0, referencia
            FROM movimientos_agua
            WHERE fecha = ?
            ORDER BY id
            """,
            (selected_iso,),
        ).fetchall()
        rows.extend([list(row) for row in water_movements])
        return [
            "Tipo", "Fecha", "Llenos", "Vacios", "Prest. clientes", "Prest. mayoristas",
            "Entradas mes", "Salidas mes", "Referencia"
        ], rows

    if modulo == "liquidaciones":
        rows = db.execute(
            """
            SELECT l.id, l.fecha, COALESCE(r.nombre, '') AS repartidor, COALESCE(p.cliente, '') AS cliente,
                   l.debe_entregar, l.entregado, l.diferencia, l.vuelto_yape,
                   l.fise_20_cantidad, l.fise_43_cantidad, l.total_fise_cantidad,
                   l.total_fise_valor, l.observaciones
            FROM liquidaciones_repartidores l
            LEFT JOIN repartidores r ON r.id = l.repartidor_id
            LEFT JOIN pedidos p ON p.id = l.pedido_id
            WHERE l.fecha = ?
            ORDER BY l.id
            """,
            (selected_iso,),
        ).fetchall()
        return [
            "ID", "Fecha", "Repartidor", "Cliente", "Debe entregar", "Entregado",
            "Diferencia", "Vuelto Yape", "FISE 20", "FISE 43", "Total FISES",
            "Valor FISE", "Observaciones"
        ], [
            list(row) for row in rows
        ]

    if modulo == "fiados":
        rows = db.execute(
            """
            SELECT v.id, v.fecha, v.cliente, COALESCE(p.direccion, '') AS direccion,
                   COALESCE(p.telefono, '') AS telefono, v.repartidor, v.total_venta,
                   v.pago_fiado, 'Pendiente' AS estado, v.observaciones
            FROM ventas v
            LEFT JOIN pedidos p ON p.id = v.pedido_id
            WHERE v.pago_fiado > 0
            ORDER BY v.id
            """,
            (),
        ).fetchall()
        return [
            "Venta", "Fecha", "Cliente", "Direccion", "Telefono", "Repartidor",
            "Total venta", "Monto adeudado", "Estado", "Observaciones"
        ], [list(row) for row in rows]

    if modulo == "repartidores":
        rows = build_driver_summary(db, selected_date)
        return [
            "Repartidor", "Total vendido", "Total cobrado", "Total pendiente",
            "Debe entregar", "Entregado", "Diferencia", "Ganancia",
            "Vuelto Yape", "FISE 20", "FISE 43", "Total FISES", "Valor FISE"
        ], [
            [
                row["driver"], row["total_vendido"], row["total_cobrado"], row["total_pendiente"],
                row["debe_entregar"], row["dinero_entregado"], row["diferencia"], row["ganancia"],
                row["vuelto_yape"], row["fise_20_cantidad"], row["fise_43_cantidad"],
                row["total_fise_cantidad"], row["total_fise_valor"]
            ]
            for row in rows
        ]

    if modulo == "fises":
        rows = db.execute(
            """
            SELECT f.id, f.fecha, COALESCE(r.nombre, '') AS repartidor,
                   f.cantidad_20, f.cantidad_43,
                   CASE WHEN f.cantidad_20 > 0 OR f.cantidad_43 > 0 THEN f.cantidad_20 + f.cantidad_43 ELSE f.cantidad END AS cantidad,
                   f.total_fise, f.observaciones
            FROM fises_repartidores f
            LEFT JOIN repartidores r ON r.id = f.repartidor_id
            WHERE f.fecha = ?
            ORDER BY f.id
            """,
            (selected_iso,),
        ).fetchall()
        return ["ID", "Fecha", "Repartidor", "FISE 20", "FISE 43", "Cantidad", "Total FISE", "Observaciones"], [list(row) for row in rows]

    raise ValueError("Reporte no disponible.")


@app.route("/exportar/<modulo>")
def exportar_reporte(modulo):
    selected_date = selected_date_from_request()
    try:
        with get_connection() as db:
            headers, rows = export_rows(db, modulo, selected_date)
        output = make_xlsx(modulo.title(), headers, rows)
        return send_file(
            output,
            as_attachment=True,
            download_name=f"{modulo}_{selected_date.isoformat()}.xlsx",
            mimetype="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        )
    except ValueError as error:
        flash(str(error), "danger")
        return redirect_to_dashboard(selected_date.isoformat(), "pedidosPanel")


def update_sale_record(db, venta_id, form_prefix=""):
    sale = db.execute("SELECT * FROM ventas WHERE id = ?", (venta_id,)).fetchone()
    if not sale:
        raise ValueError("No se encontro la venta seleccionada.")

    fecha = text_from_form(f"{form_prefix}fecha") or sale["fecha"]
    cliente = text_from_form(f"{form_prefix}cliente")
    repartidor = text_from_form(f"{form_prefix}repartidor")
    producto = text_from_form(f"{form_prefix}producto") or sale["producto"] or "BALON DE GAS 10 KG"
    tipo_valvula = validate_product_fields(producto, text_from_form(f"{form_prefix}tipo_valvula") or sale["tipo_valvula"] or "VALVULA NORMAL")
    cantidad = number_from_form(f"{form_prefix}cantidad", default=int(sale["cantidad"] or 1), integer=True)
    costo_balon = number_from_form(f"{form_prefix}costo_balon")
    precio_venta = number_from_form(f"{form_prefix}precio_venta")
    payments = payment_amounts_from_form(f"{form_prefix}pago_")
    vuelto_yape = number_from_form(f"{form_prefix}pago_vuelto_yape")
    dinero_entregado = number_from_form(f"{form_prefix}dinero_entregado")
    observaciones = text_from_form(f"{form_prefix}observaciones")

    if cantidad <= 0:
        raise ValueError("La cantidad debe ser mayor a cero.")
    if costo_balon < 0 or precio_venta <= 0:
        raise ValueError("Revise costo y precio de venta.")
    if min(payments.values()) < 0 or dinero_entregado < 0 or vuelto_yape < 0:
        raise ValueError("Los pagos no pueden ser negativos.")

    total_costo = costo_balon * cantidad
    total_venta = precio_venta * cantidad
    if round(net_payment_amount(payments, vuelto_yape), 2) != round(total_venta, 2):
        raise ValueError("Los pagos deben sumar exactamente el total.")

    repartidor_id, repartidor_nombre = get_or_create_driver(db, repartidor)
    old_items = get_sale_items(db, sale)
    new_items = [build_item(producto, tipo_valvula, cantidad, costo_balon, precio_venta)]
    adjust_inventory_for_items(db, old_items, -1)
    adjust_inventory_for_items(db, new_items, 1)

    ganancia = total_venta - total_costo
    dinero_pendiente = payments["fiado"] + max(payments["efectivo"] - dinero_entregado, 0)
    items_resumen = summarize_items(new_items)
    db.execute(
        """
        UPDATE ventas
        SET fecha = ?,
            cliente = ?,
            repartidor = ?,
            repartidor_id = ?,
            cantidad = ?,
            producto = ?,
            tipo_valvula = ?,
            costo_balon = ?,
            precio_venta = ?,
            total_costo = ?,
            total_venta = ?,
            ganancia = ?,
            pago_efectivo = ?,
            pago_yape = ?,
            pago_yape_marcos = ?,
            pago_plin = ?,
            pago_fise = ?,
            pago_fiado = ?,
            pago_vuelto_yape = ?,
            dinero_entregado = ?,
            dinero_pendiente = ?,
            monto = ?,
            observaciones = ?,
            items_resumen = ?
        WHERE id = ?
        """,
        (
            fecha,
            cliente,
            repartidor_nombre,
            repartidor_id,
            cantidad,
            producto,
            tipo_valvula,
            costo_balon,
            precio_venta,
            total_costo,
            total_venta,
            ganancia,
            payments["efectivo"],
            payments["yape"],
            payments["yape_marcos"],
            payments["plin"],
            payments["fise"],
            payments["fiado"],
            vuelto_yape,
            dinero_entregado,
            dinero_pendiente,
            total_venta,
            observaciones,
            items_resumen,
            venta_id,
        ),
    )
    save_sale_items(db, venta_id, new_items)
    db.execute(
        """
        INSERT INTO ganancias (venta_id, fecha, repartidor_id, ganancia)
        VALUES (?, ?, ?, ?)
        ON CONFLICT(venta_id) DO UPDATE SET
            fecha = excluded.fecha,
            repartidor_id = excluded.repartidor_id,
            ganancia = excluded.ganancia
        """,
        (venta_id, fecha, repartidor_id, ganancia),
    )
    save_sale_payments(db, venta_id, payments)

    if sale["pedido_id"]:
        pedido_id = int(sale["pedido_id"])
        clear_order_account_movements(db, pedido_id)
        record_payment_account_movements(db, fecha, payments, f"Pedido #{pedido_id}")
        record_vuelto_yape_movement(db, fecha, vuelto_yape, f"Pedido #{pedido_id}")
        record_account_movement(db, fecha, "caja", "ingreso", dinero_entregado, f"Liquidacion pedido #{pedido_id}")
        db.execute(
            """
            UPDATE pedidos
            SET fecha = ?,
                cliente = ?,
                cantidad = ?,
                producto = ?,
                tipo_valvula = ?,
                costo_producto = ?,
                precio_venta = ?,
                ganancia_estimada = ?,
                items_resumen = ?,
                repartidor_id = ?,
                updated_at = CURRENT_TIMESTAMP
            WHERE id = ?
            """,
            (fecha, cliente, cantidad, producto, tipo_valvula, costo_balon, precio_venta, ganancia, items_resumen, repartidor_id, pedido_id),
        )
        save_order_items(db, pedido_id, new_items)
        db.execute(
            """
            UPDATE liquidaciones_repartidores
            SET fecha = ?,
                repartidor_id = ?,
                debe_entregar = ?,
                entregado = ?,
                diferencia = ?,
                vuelto_yape = ?,
                observaciones = ?
            WHERE venta_id = ?
            """,
            (
                fecha,
                repartidor_id,
                payments["efectivo"],
                dinero_entregado,
                dinero_entregado - payments["efectivo"],
                vuelto_yape,
                observaciones,
                venta_id,
            ),
        )
    else:
        clear_sale_account_movements(db, venta_id)
        record_payment_account_movements(db, fecha, payments, f"Venta #{venta_id}")
        record_vuelto_yape_movement(db, fecha, vuelto_yape, f"Venta #{venta_id}")

    log_change(db, "ventas", venta_id, "editar", "Venta actualizada")
    return fecha


def delete_sale_record(db, venta_id):
    sale = db.execute("SELECT * FROM ventas WHERE id = ?", (venta_id,)).fetchone()
    if not sale:
        raise ValueError("No se encontro la venta seleccionada.")
    fecha = sale["fecha"]
    if sale["pedido_id"]:
        pedido_id = int(sale["pedido_id"])
        clear_order_account_movements(db, pedido_id)
        db.execute("DELETE FROM liquidaciones_repartidores WHERE venta_id = ? OR pedido_id = ?", (venta_id, pedido_id))
        db.execute(
            """
            UPDATE pedidos
            SET estado = 'entregado',
                venta_id = NULL,
                liquidado_at = NULL,
                updated_at = CURRENT_TIMESTAMP
            WHERE id = ?
            """,
            (pedido_id,),
        )
    else:
        adjust_inventory_for_items(db, get_sale_items(db, sale), -1)
        clear_sale_account_movements(db, venta_id)

    db.execute("DELETE FROM pagos_venta WHERE venta_id = ?", (venta_id,))
    db.execute("DELETE FROM venta_items WHERE venta_id = ?", (venta_id,))
    db.execute("DELETE FROM ganancias WHERE venta_id = ?", (venta_id,))
    db.execute("DELETE FROM ventas WHERE id = ?", (venta_id,))
    log_change(db, "ventas", venta_id, "eliminar", "Venta eliminada")
    return fecha


def void_order_record(db, pedido_id):
    pedido = db.execute("SELECT * FROM pedidos WHERE id = ?", (pedido_id,)).fetchone()
    if not pedido:
        raise ValueError("No se encontro el pedido seleccionado.")
    if pedido["estado"] == "anulado":
        return pedido["fecha"]

    if pedido["venta_id"]:
        delete_sale_record(db, int(pedido["venta_id"]))
    if pedido["estado"] in {"entregado", "liquidado"}:
        adjust_inventory_for_items(db, get_order_items(db, pedido), -1)

    db.execute(
        """
        UPDATE pedidos
        SET estado = 'anulado',
            venta_id = NULL,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = ?
        """,
        (pedido_id,),
    )
    log_change(db, "pedidos", pedido_id, "anular", "Pedido anulado")
    return pedido["fecha"]


def dispatch_order_record(db, pedido_id, repartidor, observaciones=""):
    pedido = db.execute("SELECT * FROM pedidos WHERE id = ?", (pedido_id,)).fetchone()
    if not pedido:
        raise ValueError("No se encontro el pedido seleccionado.")
    if pedido["estado"] not in {"pendiente", "en_ruta"}:
        raise ValueError("Solo se pueden despachar pedidos pendientes o en ruta.")
    repartidor_id, _ = get_or_create_driver(db, repartidor)
    db.execute(
        """
        UPDATE pedidos
        SET repartidor_id = ?,
            despacho_observaciones = ?,
            estado = 'en_ruta',
            updated_at = CURRENT_TIMESTAMP
        WHERE id = ?
        """,
        (repartidor_id, observaciones, pedido_id),
    )
    return pedido["fecha"]


def deliver_order_record(db, pedido_id):
    pedido = db.execute("SELECT * FROM pedidos WHERE id = ?", (pedido_id,)).fetchone()
    if not pedido:
        raise ValueError("No se encontro el pedido seleccionado.")
    if pedido["estado"] != "en_ruta":
        raise ValueError("El pedido debe estar en ruta antes de marcarlo entregado.")
    if not pedido["repartidor_id"]:
        raise ValueError("Asigne un repartidor antes de entregar.")

    items = get_order_items(db, pedido)
    adjust_inventory_for_items(db, items, 1)
    db.execute(
        """
        UPDATE pedidos
        SET estado = 'entregado',
            entregado_at = CURRENT_TIMESTAMP,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = ?
        """,
        (pedido_id,),
    )
    record_inventory_movements_for_items(db, pedido["fecha"], items, f"Pedido #{pedido_id}", "pedido_entregado")
    return pedido["fecha"]


def liquidate_order_record(db, pedido_id, payments, dinero_entregado, observaciones="", fise_counts=None, vuelto_yape=0):
    fise_counts = fise_counts or {"cantidad_20": 0, "cantidad_43": 0, "cantidad_total": 0, "valor_total": 0}
    pedido = db.execute(
        """
        SELECT p.*, r.nombre AS repartidor
        FROM pedidos p
        LEFT JOIN repartidores r ON r.id = p.repartidor_id
        WHERE p.id = ?
        """,
        (pedido_id,),
    ).fetchone()
    if not pedido:
        raise ValueError("No se encontro el pedido seleccionado.")
    if pedido["estado"] != "entregado":
        raise ValueError("Solo se pueden liquidar pedidos entregados.")
    if not pedido["repartidor_id"]:
        raise ValueError("El pedido no tiene repartidor asignado.")

    items = get_order_items(db, pedido)
    totals = item_totals(items)
    primary = items[0]
    total_venta = totals["total_venta"]
    total_costo = totals["total_costo"]
    if total_venta <= 0:
        raise ValueError("Registre el precio del pedido antes de liquidar.")
    if round(net_payment_amount(payments, vuelto_yape), 2) != round(total_venta, 2):
        raise ValueError("Los pagos deben sumar exactamente el total del pedido.")

    pago_efectivo = payments["efectivo"]
    diferencia = dinero_entregado - pago_efectivo
    ganancia = total_venta - total_costo
    dinero_pendiente = payments["fiado"] + max(pago_efectivo - dinero_entregado, 0)
    items_resumen = summarize_items(items)

    cursor = db.execute(
        """
        INSERT INTO ventas
            (fecha, cliente, repartidor, repartidor_id, cantidad, producto, tipo_valvula, costo_balon,
             precio_venta, total_costo, total_venta, ganancia, pago_efectivo,
             pago_yape, pago_yape_marcos, pago_plin, pago_fise, pago_fiado, pago_vuelto_yape,
             dinero_entregado, dinero_pendiente, monto, pedido_id, observaciones, items_resumen)
        VALUES
            (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """,
        (
            pedido["fecha"],
            pedido["cliente"],
            pedido["repartidor"],
            pedido["repartidor_id"],
            int(totals["cantidad"] or 0),
            primary["producto"],
            primary["tipo_valvula"] or "",
            primary["costo_unitario"],
            primary["precio_unitario"],
            total_costo,
            total_venta,
            ganancia,
            payments["efectivo"],
            payments["yape"],
            payments["yape_marcos"],
            payments["plin"],
            payments["fise"],
            payments["fiado"],
            vuelto_yape,
            dinero_entregado,
            dinero_pendiente,
            total_venta,
            pedido_id,
            observaciones,
            items_resumen,
        ),
    )
    venta_id = cursor.lastrowid
    save_sale_items(db, venta_id, items)
    save_sale_payments(db, venta_id, payments)
    db.execute(
        "INSERT INTO ganancias (venta_id, fecha, repartidor_id, ganancia) VALUES (?, ?, ?, ?)",
        (venta_id, pedido["fecha"], pedido["repartidor_id"], ganancia),
    )
    db.execute(
        """
        INSERT INTO liquidaciones_repartidores
            (fecha, repartidor_id, debe_entregar, entregado, diferencia, vuelto_yape,
             fise_20_cantidad, fise_43_cantidad, total_fise_cantidad, total_fise_valor,
             pedido_id, venta_id, observaciones)
        VALUES
            (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """,
        (
            pedido["fecha"],
            pedido["repartidor_id"],
            pago_efectivo,
            dinero_entregado,
            diferencia,
            vuelto_yape,
            fise_counts["cantidad_20"],
            fise_counts["cantidad_43"],
            fise_counts["cantidad_total"],
            fise_counts["valor_total"],
            pedido_id,
            venta_id,
            observaciones,
        ),
    )
    record_payment_account_movements(db, pedido["fecha"], payments, f"Pedido #{pedido_id}")
    record_vuelto_yape_movement(db, pedido["fecha"], vuelto_yape, f"Pedido #{pedido_id}")
    record_account_movement(db, pedido["fecha"], "caja", "ingreso", dinero_entregado, f"Liquidacion pedido #{pedido_id}")
    db.execute(
        """
        UPDATE pedidos
        SET estado = 'liquidado',
            venta_id = ?,
            liquidado_at = CURRENT_TIMESTAMP,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = ?
        """,
        (venta_id, pedido_id),
    )
    return pedido["fecha"]


@app.route("/precios", methods=["POST"])
def registrar_precio():
    fecha = text_from_form("fecha") or today_iso()
    try:
        costo_balon = number_from_form("costo_balon")
        precio_venta = number_from_form("precio_venta")
        observaciones = text_from_form("observaciones")
        if costo_balon < 0:
            raise ValueError("El costo del balon no puede ser negativo.")
        if precio_venta <= 0:
            raise ValueError("El precio de venta debe ser mayor a cero.")
        if precio_venta < costo_balon:
            raise ValueError("El precio de venta no debe ser menor al costo.")

        with get_connection() as db:
            db.execute(
                """
                INSERT INTO precios_gas (fecha, costo_balon, precio_venta, observaciones)
                VALUES (?, ?, ?, ?)
                ON CONFLICT(fecha) DO UPDATE SET
                    costo_balon = excluded.costo_balon,
                    precio_venta = excluded.precio_venta,
                    observaciones = excluded.observaciones
                """,
                (fecha, costo_balon, precio_venta, observaciones),
            )
            db.commit()
        flash("Precio diario guardado correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")
    return redirect_to_dashboard(fecha)


@app.route("/pedidos", methods=["POST"])
def registrar_pedido():
    fecha = text_from_form("fecha") or today_iso()
    try:
        cliente = text_from_form("cliente")
        telefono = text_from_form("telefono")
        direccion = text_from_form("direccion")
        items = parse_order_items_from_form()
        totals = item_totals(items)
        primary = items[0]
        cantidad = totals["cantidad"]
        producto = primary["producto"]
        tipo_valvula = primary["tipo_valvula"]
        costo_producto = primary["costo_unitario"]
        precio_venta = primary["precio_unitario"]
        observaciones = text_from_form("observaciones")
        items_resumen = summarize_items(items)

        if not cliente:
            raise ValueError("Ingrese el cliente del pedido.")
        if not direccion:
            raise ValueError("Ingrese la direccion de entrega.")
        ganancia_estimada = totals["ganancia"]

        with get_connection() as db:
            cursor = db.execute(
                """
                INSERT INTO pedidos
                    (fecha, cliente, telefono, direccion, cantidad, producto, tipo_valvula,
                     costo_producto, precio_venta, ganancia_estimada, items_resumen, observaciones, estado)
                VALUES
                    (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'pendiente')
                """,
                (
                    fecha,
                    cliente,
                    telefono,
                    direccion,
                    cantidad,
                    producto,
                    tipo_valvula,
                    costo_producto,
                    precio_venta,
                    ganancia_estimada,
                    items_resumen,
                    observaciones,
                ),
            )
            save_order_items(db, cursor.lastrowid, items)
            db.commit()
        flash("Pedido registrado correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")

    return redirect_to_dashboard(fecha, "pedidosPanel")


@app.route("/pedidos/<int:pedido_id>/editar", methods=["POST"])
def editar_pedido(pedido_id):
    fecha = text_from_form("fecha") or today_iso()
    try:
        with get_connection() as db:
            pedido = db.execute("SELECT * FROM pedidos WHERE id = ?", (pedido_id,)).fetchone()
            if not pedido:
                raise ValueError("No se encontro el pedido seleccionado.")
            fecha = text_from_form("fecha") or pedido["fecha"]
            cliente = text_from_form("cliente")
            telefono = text_from_form("telefono")
            direccion = text_from_form("direccion")
            if text_from_form("producto"):
                items = parse_order_items_from_form()
            else:
                items = get_order_items(db, pedido)
            totals = item_totals(items)
            primary = items[0]
            cantidad = totals["cantidad"]
            producto = primary["producto"]
            tipo_valvula = primary["tipo_valvula"]
            costo_producto = primary["costo_unitario"]
            precio_venta = primary["precio_unitario"]
            estado = text_from_form("estado") or pedido["estado"]
            repartidor = text_from_form("repartidor")
            observaciones = text_from_form("observaciones")
            items_resumen = summarize_items(items)

            if estado == "anulado":
                fecha = void_order_record(db, pedido_id)
                db.commit()
                flash("Pedido anulado correctamente.", "success")
                return redirect_to_dashboard(fecha, "pedidosPanel")

            if estado not in ORDER_STATES:
                raise ValueError("Estado de pedido no valido.")
            if not cliente or not direccion:
                raise ValueError("Cliente y direccion son obligatorios.")
            if cantidad <= 0:
                raise ValueError("La cantidad debe ser mayor a cero.")
            if costo_producto < 0 or precio_venta <= 0:
                raise ValueError("Revise costo y precio del pedido.")
            old_items = get_order_items(db, pedido)
            old_totals = item_totals(old_items)
            financial_data_changed = (
                summarize_items(old_items) != items_resumen
                or round(old_totals["total_costo"], 2) != round(totals["total_costo"], 2)
                or round(old_totals["total_venta"], 2) != round(totals["total_venta"], 2)
            )
            if pedido["estado"] == "liquidado" and financial_data_changed:
                raise ValueError("Para cambiar producto, costo o precio de un pedido liquidado, edite la venta/liquidacion.")
            if pedido["estado"] == "entregado" and financial_data_changed:
                adjust_inventory_for_items(db, old_items, -1)
                adjust_inventory_for_items(db, items, 1)
            ganancia_estimada = totals["ganancia"]

            repartidor_id = pedido["repartidor_id"]
            if repartidor:
                repartidor_id, _ = get_or_create_driver(db, repartidor)

            db.execute(
                """
                UPDATE pedidos
                SET fecha = ?,
                    cliente = ?,
                    telefono = ?,
                    direccion = ?,
                    cantidad = ?,
                    producto = ?,
                    tipo_valvula = ?,
                    costo_producto = ?,
                    precio_venta = ?,
                    ganancia_estimada = ?,
                    items_resumen = ?,
                    observaciones = ?,
                    estado = ?,
                    repartidor_id = ?,
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = ?
                """,
                (
                    fecha,
                    cliente,
                    telefono,
                    direccion,
                    cantidad,
                    producto,
                    tipo_valvula,
                    costo_producto,
                    precio_venta,
                    ganancia_estimada,
                    items_resumen,
                    observaciones,
                    estado,
                    repartidor_id,
                    pedido_id,
                ),
            )
            save_order_items(db, pedido_id, items)
            log_change(db, "pedidos", pedido_id, "editar", "Pedido actualizado")
            db.commit()
        flash("Pedido actualizado correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")

    return redirect_to_dashboard(fecha, "pedidosPanel")


@app.route("/pedidos/<int:pedido_id>/anular", methods=["POST"])
def anular_pedido(pedido_id):
    fecha = text_from_form("fecha") or today_iso()
