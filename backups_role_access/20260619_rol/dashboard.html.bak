        <article class="panel form-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Agua</p>
              <h2>Inventario de agua</h2>
            </div>
          </div>
          <form id="inventarioAguaForm" action="{{ url_for('actualizar_inventario_agua') }}" method="post" class="dashboard-form">
            <input type="hidden" name="fecha" value="{{ selected_date }}">
            <div class="row g-3">
              <div class="col-sm-6">
                <label class="form-label" for="agua_llenos">Bidones llenos</label>
                <input class="form-control" id="agua_llenos" name="agua_llenos" type="number" min="0" step="1" value="{{ water_inventory.llenos }}" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="agua_vacios">Bidones vacios</label>
                <input class="form-control" id="agua_vacios" name="agua_vacios" type="number" min="0" step="1" value="{{ water_inventory.vacios }}" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="agua_entradas_mes">Entradas mes</label>
                <input class="form-control" id="agua_entradas_mes" name="agua_entradas_mes" type="number" min="0" step="1" value="{{ water_inventory.entradas_mes }}" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="agua_salidas_mes">Salidas mes</label>
                <input class="form-control" id="agua_salidas_mes" name="agua_salidas_mes" type="number" min="0" step="1" value="{{ water_inventory.salidas_mes }}" required>
              </div>
            </div>
            <button class="primary-button form-submit" type="submit">Guardar agua</button>
          </form>
        </article>
      </section>

      <section class="content-grid">
        <article class="panel wide-panel" id="repartidoresPanel">
          <div class="panel-heading">
            <div>
              <p class="eyebrow">Control de repartidores</p>
              <h2>Resumen por repartidor</h2>
            </div>
            <span class="trend-pill">{{ date_label }}</span>
          </div>
          <div class="table-wrap">
            <table class="driver-table">
              <thead>
                <tr>
                  <th>Repartidor</th>
                  <th>Total vendido</th>
                  <th>Total cobrado</th>
                  <th>Total pendiente</th>
                  <th>Debe entregar</th>
                  <th>Ya entrego</th>
                  <th>Diferencia</th>
                  <th>Ganancia</th>
                  <th>FISE / Vuelto</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="driversTable"></tbody>
            </table>
          </div>
        </article>

        <article class="panel liquidation-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Liquidaciones</p>
              <h2>Entregas del dia</h2>
            </div>
          </div>
          <div class="mini-list" id="liquidationHistoryList"></div>
        </article>

        <article class="panel fise-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">FISE</p>
              <h2>FISES del dia</h2>
            </div>
          </div>
          <dl class="month-list">
            <div><dt>FISE S/ 20</dt><dd id="fise20Count">{{ fise_report.cantidad_20 }}</dd></div>
            <div><dt>FISE S/ 43</dt><dd id="fise43Count">{{ fise_report.cantidad_43 }}</dd></div>
            <div><dt>Cantidad</dt><dd id="fiseCount">{{ fise_report.cantidad }}</dd></div>
            <div><dt>Total FISE</dt><dd id="fiseTotal">{{ fise_report.total|soles }}</dd></div>
          </dl>
          <div class="mini-list" id="fiseHistoryList"></div>
        </article>

        <article class="panel wide-panel" id="fiseLiquidationPanel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Liquidacion de FISES</p>
              <h2>FISES fisicos pendientes de entrega</h2>
            </div>
            <span class="trend-pill">{{ date_label }}</span>
          </div>
          <div class="table-wrap compact-table">
            <table class="credit-table">
              <thead>
                <tr>
                  <th>Repartidor</th>
                  <th>Fecha</th>
                  <th>FISE S/ 20</th>
                  <th>FISE S/ 43</th>
                  <th>Total FISES</th>
                  <th>Valor total</th>
                  <th>Estado</th>
                  <th>Accion</th>
                </tr>
              </thead>
              <tbody id="fiseLiquidationTable"></tbody>
            </table>
          </div>
        </article>

        <article class="panel account-movements-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Cuentas</p>
              <h2>Movimientos del dia</h2>
            </div>
          </div>
          <div class="mini-list" id="accountMovementsList"></div>
        </article>

        <article class="panel payment-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Cierre de pagos</p>
              <h2>Pagos del dia</h2>
            </div>
          </div>
          <dl class="month-list">
            <div><dt>Efectivo</dt><dd class="positive" id="paymentCash">{{ payment_summary.efectivo|soles }}</dd></div>
            <div><dt>Yape</dt><dd id="paymentYape">{{ payment_summary.yape|soles }}</dd></div>
            <div><dt>Yape Marcos</dt><dd id="paymentYapeMarcos">{{ payment_summary.yape_marcos|soles }}</dd></div>
            <div><dt>Plin</dt><dd id="paymentPlin">{{ payment_summary.plin|soles }}</dd></div>
            <div><dt>FISE</dt><dd id="paymentFise">{{ payment_summary.fise|soles }}</dd></div>
            <div><dt>Fiados</dt><dd class="negative" id="paymentCredit">{{ payment_summary.fiado|soles }}</dd></div>
            <div><dt>Vuelto Yape</dt><dd class="negative" id="paymentYapeChange">{{ payment_summary.vuelto_yape|soles }}</dd></div>
            <div><dt>Total vendido</dt><dd id="paymentTotal">{{ payment_summary.total|soles }}</dd></div>
            <div><dt>Cuadre</dt><dd id="paymentStatus">{{ "Correcto" if payment_summary.cuadre else "Revisar" }}</dd></div>
          </dl>
        </article>

        <article class="panel wide-panel" id="clientesFiadosPanel">
          <div class="panel-heading">
            <div>
              <p class="eyebrow">Cobranzas</p>
              <h2>Clientes fiados</h2>
            </div>
            <a class="primary-button export-link" href="{{ url_for('exportar_reporte', modulo='fiados', fecha=selected_date) }}">Exportar fiados</a>
          </div>
          <div class="quick-filters sticky-filters">
            <label>
              <span>Cliente</span>
              <input class="form-control form-control-sm" id="creditFilterClient" type="search" placeholder="Buscar cliente">
            </label>
            <label>
              <span>Fecha</span>
              <input class="form-control form-control-sm" id="creditFilterDate" type="date">
            </label>
            <label>
              <span>Repartidor</span>
              <input class="form-control form-control-sm" id="creditFilterDriver" type="search" placeholder="Buscar repartidor">
            </label>
            <label>
              <span>Estado</span>
              <select class="form-select form-select-sm" id="creditFilterStatus">
                <option value="">Todos</option>
                <option value="Fiado pendiente">Fiado pendiente</option>
                <option value="Fiado liquidado">Fiado liquidado</option>
              </select>
            </label>
          </div>
          <div class="table-wrap compact-table">
            <table class="credit-table">
              <thead>
                <tr>
                  <th>Cliente</th>
                  <th>Direccion</th>
                  <th>Telefono</th>
                  <th>Fecha</th>
                  <th>Repartidor</th>
                  <th>Monto adeudado</th>
                  <th>Dias atraso</th>
                  <th>Estado</th>
                  <th>Accion</th>
                </tr>
              </thead>
              <tbody id="creditClientsTable"></tbody>
            </table>
          </div>
        </article>

        <article class="panel product-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Productos</p>
              <h2>Ventas por producto</h2>
            </div>
          </div>
          <div class="mini-list" id="productSalesList"></div>
        </article>

        <article class="panel valve-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Valvulas</p>
              <h2>Ventas por valvula</h2>
            </div>
          </div>
          <div class="mini-list" id="valveSalesList"></div>
        </article>

        <article class="panel stock-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Control diario</p>
              <h2>Cuadre de stock</h2>
            </div>
          </div>
          <dl class="month-list">
            <div><dt>Inicio llenos</dt><dd id="stockStart">{{ stock_control.inicio_llenos if stock_control.inicio_llenos is not none else "Sin registro" }}</dd></div>
            <div><dt>Ventas</dt><dd id="stockSales">{{ stock_control.ventas }}</dd></div>
            <div><dt>Prestamos llenos</dt><dd id="stockLoans">{{ stock_control.prestamos_llenos }}</dd></div>
            <div><dt>Stock final calculado</dt><dd id="stockFinal">{{ stock_control.stock_final if stock_control.stock_final is not none else "-" }}</dd></div>
            <div><dt>Inventario actual</dt><dd id="stockCurrentCheck">{{ stock_control.inventario_actual }}</dd></div>
            <div><dt>Estado</dt><dd id="stockStatus">{{ "Cuadra" if stock_control.cuadra else "Revisar" }}</dd></div>
          </dl>
        </article>

        <article class="panel table-panel">
          <div class="panel-heading">
            <div>
              <p class="eyebrow">Historial de movimientos</p>
              <h2>Ventas y gastos registrados</h2>
            </div>
            <span class="trend-pill">{{ date_label }}</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Movimiento</th>
                  <th>Tipo</th>
                  <th>Repartidor</th>
                  <th>Monto</th>
                  <th>Ganancia</th>
                  <th>Observaciones</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="movementsTable"></tbody>
            </table>
          </div>
        </article>

        <article class="panel inventory-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Almacen</p>
              <h2>Inventario actual</h2>
            </div>
          </div>
          <div class="inventory-grid">
            <div class="inventory-stat">
              <span class="status-dot green"></span>
              <strong id="inventoryFull">{{ inventory.llenos }}</strong>
              <span>Llenos</span>
            </div>
            <div class="inventory-stat">
              <span class="status-dot red"></span>
              <strong id="inventoryEmpty">{{ inventory.vacios }}</strong>
              <span>Vacios</span>
            </div>
            <div class="inventory-stat">
              <span class="status-dot blue"></span>
              <strong id="inventoryIn">{{ inventory.entradas_mes }}</strong>
              <span>Entradas mes</span>
            </div>
            <div class="inventory-stat">
              <span class="status-dot orange"></span>
              <strong id="inventoryOut">{{ inventory.salidas_mes }}</strong>
              <span>Salidas mes</span>
            </div>
            <div class="inventory-stat">
              <span class="status-dot blue"></span>
              <strong id="inventoryLoanClients">{{ inventory.prestados_clientes }}</strong>
              <span>Prest. clientes</span>
            </div>
            <div class="inventory-stat">
              <span class="status-dot orange"></span>
              <strong id="inventoryLoanWholesalers">{{ inventory.prestados_mayoristas }}</strong>
              <span>Prest. mayoristas</span>
            </div>
          </div>
        </article>

        <article class="panel water-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Agua</p>
              <h2>Inventario de agua</h2>
            </div>
          </div>
          <div class="inventory-grid">
            <div class="inventory-stat">
              <span class="status-dot blue"></span>
              <strong id="waterFull">{{ water_inventory.llenos }}</strong>
              <span>Llenos</span>
            </div>
            <div class="inventory-stat">
              <span class="status-dot red"></span>
              <strong id="waterEmpty">{{ water_inventory.vacios }}</strong>
              <span>Vacios</span>
            </div>
            <div class="inventory-stat">
              <span class="status-dot green"></span>
              <strong id="waterIn">{{ water_inventory.entradas_mes }}</strong>
              <span>Entradas</span>
            </div>
            <div class="inventory-stat">
              <span class="status-dot orange"></span>
              <strong id="waterOut">{{ water_inventory.salidas_mes }}</strong>
              <span>Salidas</span>
            </div>
          </div>
          <div class="mini-list" id="waterMovementsList"></div>
        </article>

        <article class="panel inventory-movements-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Inventario</p>
              <h2>Movimientos de gas</h2>
            </div>
          </div>
          <div class="mini-list" id="inventoryMovementsList"></div>
        </article>

        <article class="panel loan-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Prestamos</p>
              <h2>Balones prestados</h2>
            </div>
          </div>
          <dl class="month-list">
            <div><dt>Clientes</dt><dd id="loanedClients">{{ loans.clientes }}</dd></div>
            <div><dt>Mayoristas</dt><dd id="loanedWholesalers">{{ loans.mayoristas }}</dd></div>
          </dl>
          <div class="mini-list" id="loansList"></div>
        </article>

        <article class="panel price-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Historial</p>
              <h2>Precios de gas</h2>
            </div>
          </div>
          <div class="mini-list" id="priceHistoryList"></div>
        </article>

        <article class="panel chart-panel wide">
          <div class="panel-heading">
            <div>
              <p class="eyebrow">Ventas</p>
              <h2>Ventas de los ultimos 7 dias</h2>
            </div>
            <span class="trend-pill" id="salesTrend">7 dias</span>
          </div>
          <div class="bar-chart" id="salesChart" aria-label="Grafico de barras de ventas"></div>
        </article>

        <article class="panel donut-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Gastos</p>
              <h2>Gastos por categoria</h2>
            </div>
          </div>
          <div class="donut-layout">
            <div class="donut" id="expenseDonut" aria-hidden="true"></div>
            <div class="legend" id="expenseLegend"></div>
          </div>
          <div class="panel-total">
            <span>Total</span>
            <strong id="expenseTotal">{{ expense_total|soles }}</strong>
          </div>
        </article>

        <article class="panel month-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Finanzas</p>
              <h2>Resumen del mes</h2>
            </div>
          </div>
          <dl class="month-list">
            <div><dt>Total ingresos</dt><dd class="positive" id="monthIncome">{{ month_summary.income|soles }}</dd></div>
            <div><dt>Total egresos</dt><dd class="negative" id="monthExpense">{{ month_summary.expense|soles }}</dd></div>
            <div><dt>Ganancia ventas</dt><dd id="monthGrossProfit">{{ month_summary.gross_profit|soles }}</dd></div>
            <div><dt>Ganancia neta</dt><dd id="monthProfit">{{ month_summary.profit|soles }}</dd></div>
            <div><dt>Ventas realizadas</dt><dd id="monthSales">{{ month_summary.sales_count }}</dd></div>
            <div><dt>Clientes atendidos</dt><dd id="monthClients">{{ month_summary.clients_count }}</dd></div>
          </dl>
        </article>

        <article class="panel exports-panel wide-panel">
          <div class="panel-heading">
            <div>
              <p class="eyebrow">Reportes Excel</p>
              <h2>Descargas del dia</h2>
            </div>
            <span class="trend-pill">{{ date_label }}</span>
          </div>
          <div class="export-grid">
            <a href="{{ url_for('exportar_reporte', modulo='pedidos', fecha=selected_date) }}">Pedidos</a>
            <a href="{{ url_for('exportar_reporte', modulo='ventas', fecha=selected_date) }}">Ventas</a>
            <a href="{{ url_for('exportar_reporte', modulo='gastos', fecha=selected_date) }}">Gastos</a>
            <a href="{{ url_for('exportar_reporte', modulo='inventario', fecha=selected_date) }}">Inventario</a>
            <a href="{{ url_for('exportar_reporte', modulo='liquidaciones', fecha=selected_date) }}">Liquidaciones</a>
            <a href="{{ url_for('exportar_reporte', modulo='fiados', fecha=selected_date) }}">Fiados</a>
            <a href="{{ url_for('exportar_reporte', modulo='repartidores', fecha=selected_date) }}">Repartidores</a>
            <a href="{{ url_for('exportar_reporte', modulo='fises', fecha=selected_date) }}">FISES</a>
          </div>
        </article>
      </section>
    </main>
  </div>

  <div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <form class="modal-content dashboard-form" id="editForm" method="post">
        <div class="modal-header">
          <h2 class="modal-title" id="editModalTitle">Editar registro</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" name="fecha" value="{{ selected_date }}">
          <div class="row g-3" id="editFields"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="primary-button">Guardar cambios</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <form class="modal-content dashboard-form" id="deleteForm" method="post">
        <div class="modal-header">
          <h2 class="modal-title" id="deleteModalTitle">Confirmar accion</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" name="fecha" value="{{ selected_date }}">
          <p id="deleteModalText" class="mb-0">Seguro que deseas eliminar este registro?</p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="primary-button danger-submit">Confirmar</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal fade" id="creditPaymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <form class="modal-content dashboard-form" id="creditPaymentForm" method="post">
        <div class="modal-header">
          <h2 class="modal-title" id="creditPaymentTitle">Liquidar deuda</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div class="modal-body">
          <div class="calculation-strip liquidation-strip mb-3">
            <span>Cliente: <strong id="creditPaymentClient">-</strong></span>
            <span>Pendiente: <strong id="creditPaymentPending">S/ 0.00</strong></span>
            <span>Pagando: <strong id="creditPaymentAmountPreview">S/ 0.00</strong></span>
            <span>Saldo: <strong id="creditPaymentBalancePreview">S/ 0.00</strong></span>
            <span>FISES: <strong id="creditPaymentFisePreview">0 / S/ 0.00</strong></span>
            <span>Estado: <strong id="creditPaymentStatusPreview">Pendiente</strong></span>
          </div>
          <div class="row g-3">
            <div class="col-sm-6">
              <label class="form-label" for="creditPaymentDate">Fecha de pago</label>
              <input class="form-control credit-payment-calculator" id="creditPaymentDate" name="fecha_pago" type="date" value="{{ selected_date }}" required>
            </div>
            <div class="col-sm-6">
              <label class="form-label" for="creditPaymentMethod">Metodo de pago</label>
              <select class="form-select credit-payment-calculator" id="creditPaymentMethod" name="metodo_pago">
                <option value="mixto">Mixto</option>
                <option value="efectivo">Efectivo</option>
                <option value="yape">Yape</option>
                <option value="transferencia">Transferencia</option>
                <option value="fise">FISE</option>
              </select>
            </div>
            <div class="col-sm-6">
              <label class="form-label" for="creditCash">Efectivo</label>
              <input class="form-control credit-payment-calculator" id="creditCash" name="pago_efectivo" type="number" min="0" step="0.01" value="0">
            </div>
            <div class="col-sm-6">
              <label class="form-label" for="creditYape">Yape</label>
              <input class="form-control credit-payment-calculator" id="creditYape" name="pago_yape" type="number" min="0" step="0.01" value="0">
            </div>
            <div class="col-sm-6">
              <label class="form-label" for="creditTransfer">Transferencia</label>
              <input class="form-control credit-payment-calculator" id="creditTransfer" name="pago_transferencia" type="number" min="0" step="0.01" value="0">
            </div>
            <div class="col-sm-6">
              <label class="form-label" for="creditFise">FISE</label>
              <input class="form-control credit-payment-calculator" id="creditFise" name="pago_fise" type="number" min="0" step="0.01" value="0">
            </div>
            <div class="col-sm-6">
              <label class="form-label" for="creditFise20">FISE S/ 20</label>
              <input class="form-control credit-payment-calculator" id="creditFise20" name="fise_20_cantidad" type="number" min="0" step="1" value="0">
            </div>
            <div class="col-sm-6">
              <label class="form-label" for="creditFise43">FISE S/ 43</label>
              <input class="form-control credit-payment-calculator" id="creditFise43" name="fise_43_cantidad" type="number" min="0" step="1" value="0">
            </div>
            <div class="col-12">
              <label class="form-label" for="creditPaymentObservations">Observaciones</label>
              <input class="form-control" id="creditPaymentObservations" name="observaciones" type="text">
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="primary-button">Registrar pago</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    window.dashboardData = {{ dashboard_data|tojson }};
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="{{ url_for('static', filename='js/app.js') }}"></script>
</body>
</html>
