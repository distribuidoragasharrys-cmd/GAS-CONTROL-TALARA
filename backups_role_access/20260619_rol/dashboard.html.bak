              <div class="col-sm-6">
                <label class="form-label" for="pagoFecha">Fecha</label>
                <input class="form-control" id="pagoFecha" name="fecha" type="date" value="{{ selected_date }}">
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="pagoMonto">Dinero entregado</label>
                <input class="form-control" id="pagoMonto" name="monto" type="number" min="0" step="0.01" required>
