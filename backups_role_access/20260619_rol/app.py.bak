@app.route("/pedidos/despachar", methods=["POST"])
def despachar_pedido():
    fecha = text_from_form("fecha") or today_iso()
    try:
        pedido_id = number_from_form("pedido_id", integer=True)
        repartidor = text_from_form("repartidor")
        observaciones = text_from_form("observaciones")

        with get_connection() as db:
            pedido = db.execute("SELECT * FROM pedidos WHERE id = ?", (pedido_id,)).fetchone()
            if not pedido:
                raise ValueError("No se encontro el pedido seleccionado.")
            fecha = pedido["fecha"]
            if pedido["estado"] not in {"pendiente", "en_ruta"}:
                raise ValueError("Solo se pueden despachar pedidos pendientes o en ruta.")
            repartidor_id, _ = get_or_create_driver(db, repartidor)
            db.execute(
                """
                UPDATE pedidos
                SET repartidor_id = ?,
                    despacho_observaciones = ?,
                    estado = 'en_ruta',
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = ?
                """,
                (repartidor_id, observaciones, pedido_id),
            )
            db.commit()
        flash("Pedido asignado a repartidor.", "success")
    except ValueError as error:
        flash(str(error), "danger")

    return redirect_to_dashboard(fecha, "pedidosPanel")


@app.route("/pedidos/gestionar", methods=["POST"])
def gestionar_pedido():
    fecha = text_from_form("fecha") or today_iso()
    ok = True
    message = "Pedido gestionado correctamente."
    try:
        pedido_id = number_from_form("pedido_id", integer=True)
        accion = text_from_form("accion_pedido") or "despachar"
        repartidor = text_from_form("repartidor")
        observaciones = text_from_form("observaciones")
        payments, fise_counts, vuelto_yape = liquidation_amounts_from_form()
        dinero_entregado = number_from_form("dinero_entregado")

        if accion not in {"despachar", "entregar", "liquidar"}:
            raise ValueError("Seleccione una accion valida.")
        if min(payments.values()) < 0 or dinero_entregado < 0:
            raise ValueError("Los montos no pueden ser negativos.")

        with get_connection() as db:
            pedido = db.execute("SELECT * FROM pedidos WHERE id = ?", (pedido_id,)).fetchone()
            if not pedido:
                raise ValueError("No se encontro el pedido seleccionado.")
            fecha = pedido["fecha"]

            if accion == "despachar":
                fecha = dispatch_order_record(db, pedido_id, repartidor, observaciones)
                message = "Pedido asignado a repartidor."
                flash(message, "success")
            elif accion == "entregar":
                if pedido["estado"] == "pendiente":
                    fecha = dispatch_order_record(db, pedido_id, repartidor, observaciones)
                fecha = deliver_order_record(db, pedido_id)
                message = "Pedido marcado como entregado."
                flash(message, "success")
            else:
                if pedido["estado"] == "pendiente":
                    fecha = dispatch_order_record(db, pedido_id, repartidor, observaciones)
                    fecha = deliver_order_record(db, pedido_id)
                elif pedido["estado"] == "en_ruta":
                    fecha = deliver_order_record(db, pedido_id)
                fecha = liquidate_order_record(db, pedido_id, payments, dinero_entregado, observaciones, fise_counts, vuelto_yape)
                message = "Pedido liquidado correctamente."
                flash(message, "success")
            db.commit()
    except ValueError as error:
        ok = False
        message = str(error)
        flash(message, "danger")

    if request.headers.get("X-Requested-With") == "XMLHttpRequest":
        status_code = 200 if ok else 400
        return jsonify({"ok": ok, "message": message, "data": dashboard_payload(parse_iso_date(fecha))}), status_code
    return redirect_to_dashboard(fecha, "gestionPedidoForm")


@app.route("/pedidos/entregar", methods=["POST"])
def entregar_pedido():
    fecha = text_from_form("fecha") or today_iso()
    try:
        pedido_id = number_from_form("pedido_id", integer=True)

        with get_connection() as db:
            pedido = db.execute("SELECT * FROM pedidos WHERE id = ?", (pedido_id,)).fetchone()
            if not pedido:
                raise ValueError("No se encontro el pedido seleccionado.")
            fecha = pedido["fecha"]
            if pedido["estado"] != "en_ruta":
                raise ValueError("El pedido debe estar en ruta antes de marcarlo entregado.")
            if not pedido["repartidor_id"]:
                raise ValueError("Asigne un repartidor antes de entregar.")

            items = get_order_items(db, pedido)
            for item in items:
                quantity = int(item["cantidad"] or 0)
                if affects_gas_inventory(item["producto"]):
                    inventory = db.execute("SELECT llenos FROM inventario WHERE id = 1").fetchone()
                    if inventory["llenos"] < quantity:
                        raise ValueError("No hay stock suficiente de gas para entregar este pedido.")
                elif affects_water_inventory(item["producto"]):
                    water_inventory = db.execute("SELECT llenos FROM inventario_agua WHERE id = 1").fetchone()
                    if water_inventory["llenos"] < quantity:
                        raise ValueError("No hay stock suficiente de agua para entregar este pedido.")

            db.execute(
                """
                UPDATE pedidos
                SET estado = 'entregado',
                    entregado_at = CURRENT_TIMESTAMP,
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = ?
                """,
                (pedido_id,),
            )
            adjust_inventory_for_items(db, items, 1)
            record_inventory_movements_for_items(db, fecha, items, f"Pedido #{pedido_id}", "pedido_entregado")
            db.commit()
        flash("Pedido marcado como entregado.", "success")
    except ValueError as error:
        flash(str(error), "danger")

    return redirect_to_dashboard(fecha, "pedidosPanel")


@app.route("/pedidos/liquidar", methods=["POST"])
def liquidar_pedido():
    fecha = text_from_form("fecha") or today_iso()
    try:
        pedido_id = number_from_form("pedido_id", integer=True)
        payments, fise_counts, vuelto_yape = liquidation_amounts_from_form()
        dinero_entregado = number_from_form("dinero_entregado")
        observaciones = text_from_form("observaciones")

        if min(payments.values()) < 0 or dinero_entregado < 0:
            raise ValueError("Los montos de liquidacion no pueden ser negativos.")

        with get_connection() as db:
            pedido = db.execute(
                """
                SELECT p.*, r.nombre AS repartidor
                FROM pedidos p
                LEFT JOIN repartidores r ON r.id = p.repartidor_id
                WHERE p.id = ?
                """,
                (pedido_id,),
            ).fetchone()
            if not pedido:
                raise ValueError("No se encontro el pedido seleccionado.")
            fecha = pedido["fecha"]
            if pedido["estado"] != "entregado":
                raise ValueError("Solo se pueden liquidar pedidos entregados.")
            if not pedido["repartidor_id"]:
                raise ValueError("El pedido no tiene repartidor asignado.")

            items = get_order_items(db, pedido)
            totals = item_totals(items)
            primary = items[0]
            costo_balon = primary["costo_unitario"]
            precio_venta = primary["precio_unitario"]
            if totals["total_venta"] <= 0:
                raise ValueError("Registre el precio del pedido antes de liquidar.")

            cantidad = int(totals["cantidad"] or 0)
            total_costo = totals["total_costo"]
            total_venta = totals["total_venta"]
            total_pagado = net_payment_amount(payments, vuelto_yape)
            if round(total_pagado, 2) != round(total_venta, 2):
                raise ValueError("Los pagos deben sumar exactamente el total del pedido.")

            pago_efectivo = payments["efectivo"]
            diferencia = dinero_entregado - pago_efectivo
            ganancia = total_venta - total_costo
            dinero_pendiente = payments["fiado"] + max(pago_efectivo - dinero_entregado, 0)

            cursor = db.execute(
                """
                INSERT INTO ventas
                    (fecha, cliente, repartidor, repartidor_id, cantidad, producto, tipo_valvula, costo_balon,
                     precio_venta, total_costo, total_venta, ganancia, pago_efectivo,
                     pago_yape, pago_yape_marcos, pago_plin, pago_fise, pago_fiado, pago_vuelto_yape,
                     dinero_entregado, dinero_pendiente, monto, pedido_id, observaciones, items_resumen)
                VALUES
                    (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """,
                (
                    fecha,
                    pedido["cliente"],
                    pedido["repartidor"],
                    pedido["repartidor_id"],
                    cantidad,
                    primary["producto"],
                    primary["tipo_valvula"] or "",
                    costo_balon,
                    precio_venta,
                    total_costo,
                    total_venta,
                    ganancia,
                    payments["efectivo"],
                    payments["yape"],
                    payments["yape_marcos"],
                    payments["plin"],
                    payments["fise"],
                    payments["fiado"],
                    vuelto_yape,
                    dinero_entregado,
                    dinero_pendiente,
                    total_venta,
                    pedido_id,
                    observaciones,
                    summarize_items(items),
                ),
            )
            venta_id = cursor.lastrowid
            save_sale_items(db, venta_id, items)
            save_sale_payments(db, venta_id, payments)
            db.execute(
                "INSERT INTO ganancias (venta_id, fecha, repartidor_id, ganancia) VALUES (?, ?, ?, ?)",
                (venta_id, fecha, pedido["repartidor_id"], ganancia),
            )
            db.execute(
                """
                INSERT INTO liquidaciones_repartidores
                    (fecha, repartidor_id, debe_entregar, entregado, diferencia, vuelto_yape,
                     fise_20_cantidad, fise_43_cantidad, total_fise_cantidad, total_fise_valor,
                     pedido_id, venta_id, observaciones)
                VALUES
                    (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """,
                (
                    fecha,
                    pedido["repartidor_id"],
                    pago_efectivo,
                    dinero_entregado,
                    diferencia,
                    vuelto_yape,
                    fise_counts["cantidad_20"],
                    fise_counts["cantidad_43"],
                    fise_counts["cantidad_total"],
                    fise_counts["valor_total"],
                    pedido_id,
                    venta_id,
                    observaciones,
                ),
            )
            for tipo, monto in payments.items():
                account_code = PAYMENT_TO_ACCOUNT.get(tipo)
                if account_code:
                    record_account_movement(
                        db,
                        fecha,
                        account_code,
                        "ingreso",
                        monto,
                        f"Pedido #{pedido_id} - {tipo.replace('_', ' ').title()}",
                    )
            record_vuelto_yape_movement(db, fecha, vuelto_yape, f"Pedido #{pedido_id}")
            record_account_movement(db, fecha, "caja", "ingreso", dinero_entregado, f"Liquidacion pedido #{pedido_id}")
            db.execute(
                """
                UPDATE pedidos
                SET estado = 'liquidado',
                    venta_id = ?,
                    liquidado_at = CURRENT_TIMESTAMP,
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = ?
                """,
                (venta_id, pedido_id),
            )
            db.commit()
        flash("Pedido liquidado correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")

    return redirect_to_dashboard(fecha, "pedidosPanel")


@app.route("/ventas", methods=["POST"])
def registrar_venta():
    fecha = text_from_form("fecha") or today_iso()
    try:
        repartidor = text_from_form("repartidor")
        cliente = text_from_form("cliente")
        producto = text_from_form("producto") or "BALON DE GAS 10 KG"
        tipo_valvula = validate_product_fields(producto, text_from_form("tipo_valvula") or "VALVULA NORMAL")
        cantidad = number_from_form("cantidad", default=1, integer=True)
        costo_balon = number_from_form("costo_balon")
        precio_venta = number_from_form("precio_venta")
        pago_efectivo = number_from_form("pago_efectivo")
        pago_yape = number_from_form("pago_yape")
        pago_yape_marcos = number_from_form("pago_yape_marcos")
        pago_plin = number_from_form("pago_plin")
        pago_fise = number_from_form("pago_fise")
        pago_fiado = number_from_form("pago_fiado")
        observaciones = text_from_form("observaciones")

        if cantidad <= 0:
            raise ValueError("La cantidad debe ser mayor a cero.")
        if costo_balon < 0:
            raise ValueError("El costo del balon no puede ser negativo.")
        if precio_venta <= 0:
            raise ValueError("El precio de venta debe ser mayor a cero.")
        if min(pago_efectivo, pago_yape, pago_yape_marcos, pago_plin, pago_fise, pago_fiado) < 0:
            raise ValueError("Los pagos no pueden ser negativos.")

        total_costo = costo_balon * cantidad
        total_venta = precio_venta * cantidad
        total_pagado = pago_efectivo + pago_yape + pago_yape_marcos + pago_plin + pago_fise + pago_fiado
        if round(total_pagado, 2) != round(total_venta, 2):
            raise ValueError("Los pagos deben sumar exactamente el total de la venta.")
        ganancia = total_venta - total_costo
        sale_items = [build_item(producto, tipo_valvula, cantidad, costo_balon, precio_venta)]
        items_resumen = summarize_items(sale_items)

        with get_connection() as db:
            adjust_inventory_for_items(db, sale_items, 1)

            repartidor_id, repartidor_nombre = get_or_create_driver(db, repartidor)
            cursor = db.execute(
                """
                INSERT INTO ventas
                    (fecha, cliente, repartidor, repartidor_id, cantidad, producto, tipo_valvula, costo_balon,
                     precio_venta, total_costo, total_venta, ganancia, pago_efectivo,
                     pago_yape, pago_yape_marcos, pago_plin, pago_fise, pago_fiado, dinero_entregado,
                     dinero_pendiente, monto, observaciones, items_resumen)
                VALUES
                    (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """,
                (
                    fecha,
                    cliente,
                    repartidor_nombre,
                    repartidor_id,
                    cantidad,
                    producto,
                    tipo_valvula,
                    costo_balon,
                    precio_venta,
                    total_costo,
                    total_venta,
                    ganancia,
                    pago_efectivo,
                    pago_yape,
                    pago_yape_marcos,
                    pago_plin,
                    pago_fise,
                    pago_fiado,
                    0,
                    pago_fiado,
                    total_venta,
                    observaciones,
                    items_resumen,
                ),
            )
            venta_id = cursor.lastrowid
            save_sale_items(db, venta_id, sale_items)
            for tipo, monto in {
                "efectivo": pago_efectivo,
                "yape": pago_yape,
                "yape_marcos": pago_yape_marcos,
                "plin": pago_plin,
                "fise": pago_fise,
                "fiado": pago_fiado,
            }.items():
                if monto > 0:
                    db.execute(
                        "INSERT INTO pagos_venta (venta_id, tipo, monto) VALUES (?, ?, ?)",
                        (venta_id, tipo, monto),
                    )
                    account_code = PAYMENT_TO_ACCOUNT.get(tipo)
                    if account_code:
                        record_account_movement(
                            db,
                            fecha,
                            account_code,
                            "ingreso",
                            monto,
                            f"Venta #{venta_id} - {tipo.replace('_', ' ').title()}",
                        )
            db.execute(
                "INSERT INTO ganancias (venta_id, fecha, repartidor_id, ganancia) VALUES (?, ?, ?, ?)",
                (venta_id, fecha, repartidor_id, ganancia),
            )
            record_inventory_movements_for_items(db, fecha, sale_items, f"Venta #{venta_id}", "venta")
            db.commit()
        flash("Venta registrada correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")

    return redirect_to_dashboard(fecha)


