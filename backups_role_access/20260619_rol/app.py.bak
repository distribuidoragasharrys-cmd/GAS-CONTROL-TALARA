@app.route("/saldos-cuentas", methods=["POST"])
def registrar_saldos_cuentas():
    fecha = text_from_form("fecha") or today_iso()
    try:
        with get_connection() as db:
            for codigo in ACCOUNT_NAMES:
                saldo = number_from_form(f"saldo_{codigo}")
                if saldo < 0:
                    raise ValueError("Los saldos iniciales no pueden ser negativos.")
                account_id = get_account_id(db, codigo)
                if account_id is None:
                    continue
                db.execute(
                    """
                    INSERT INTO saldos_diarios (fecha, cuenta_id, saldo_inicial)
                    VALUES (?, ?, ?)
                    ON CONFLICT(fecha, cuenta_id) DO UPDATE SET
                        saldo_inicial = excluded.saldo_inicial,
                        updated_at = CURRENT_TIMESTAMP
                    """,
                    (fecha, account_id, saldo),
                )
            db.commit()
        flash("Saldos iniciales guardados correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")

    return redirect_to_dashboard(fecha)


@app.route("/pagos-repartidores", methods=["POST"])
def registrar_pago_repartidor():
    fecha = text_from_form("fecha") or today_iso()
    try:
        repartidor = text_from_form("repartidor")
        monto = number_from_form("monto")
        observaciones = text_from_form("observaciones")

        if monto <= 0:
            raise ValueError("El dinero entregado debe ser mayor a cero.")

        with get_connection() as db:
            repartidor_id, _ = get_or_create_driver(db, repartidor)
            debe_total = float(
                one_value(
                    db,
                    """
                    SELECT COALESCE(SUM(pago_efectivo), 0)
                    FROM ventas
                    WHERE fecha = ? AND repartidor_id = ?
                    """,
                    (fecha, repartidor_id),
                )
            )
            entregado_anterior = float(
                one_value(
                    db,
                    """
                    SELECT COALESCE(SUM(entregado), 0)
                    FROM liquidaciones_repartidores
                    WHERE fecha = ? AND repartidor_id = ?
                    """,
                    (fecha, repartidor_id),
                )
            )
            if entregado_anterior == 0:
                entregado_anterior = float(
                    one_value(
                        db,
                        """
                        SELECT COALESCE(SUM(monto), 0)
                        FROM pagos_repartidores
                        WHERE fecha = ? AND repartidor_id = ?
                        """,
                        (fecha, repartidor_id),
                    )
                )
            debe_entregar = max(debe_total - entregado_anterior, 0)
            diferencia = monto - debe_entregar
            db.execute(
                """
                INSERT INTO pagos_repartidores
                    (fecha, repartidor_id, monto, observaciones)
                VALUES
                    (?, ?, ?, ?)
                """,
                (fecha, repartidor_id, monto, observaciones),
            )
            db.execute(
                """
                INSERT INTO liquidaciones_repartidores
                    (fecha, repartidor_id, debe_entregar, entregado, diferencia, observaciones)
                VALUES
                    (?, ?, ?, ?, ?, ?)
                """,
                (fecha, repartidor_id, debe_entregar, monto, diferencia, observaciones),
            )
            record_account_movement(db, fecha, "caja", "ingreso", monto, f"Liquidacion - {repartidor}")
            db.commit()
        flash("Entrega de repartidor registrada correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")

    return redirect_to_dashboard(fecha)


