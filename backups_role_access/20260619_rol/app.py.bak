@app.route("/stock-diario", methods=["POST"])
def registrar_stock_diario():
    fecha = text_from_form("fecha") or today_iso()
    try:
        inicio_llenos = number_from_form("inicio_llenos", integer=True)
        observaciones = text_from_form("observaciones")
        if inicio_llenos < 0:
            raise ValueError("El stock inicial no puede ser negativo.")

        with get_connection() as db:
            db.execute(
                """
                INSERT INTO stock_diario (fecha, inicio_llenos, observaciones)
                VALUES (?, ?, ?)
                ON CONFLICT(fecha) DO UPDATE SET
                    inicio_llenos = excluded.inicio_llenos,
                    observaciones = excluded.observaciones,
                    updated_at = CURRENT_TIMESTAMP
                """,
                (fecha, inicio_llenos, observaciones),
            )
            db.execute(
                """
                INSERT INTO movimientos_inventario (fecha, tipo, cantidad_llenos, referencia)
                VALUES (?, 'inicio_dia', ?, 'Stock inicial del dia')
                """,
                (fecha, inicio_llenos),
            )
            db.execute(
                """
                UPDATE inventario
                SET llenos = ?,
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = 1
                """,
                (inicio_llenos,),
            )
            db.commit()
        flash("Stock inicial registrado correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")
    return redirect_to_dashboard(fecha)


@app.route("/inventario/ingreso-gas", methods=["POST"])
def registrar_ingreso_gas():
    fecha = text_from_form("fecha") or today_iso()
    try:
        cantidad = number_from_form("cantidad_ingreso", integer=True)
        observaciones = text_from_form("observaciones")
        if cantidad <= 0:
            raise ValueError("El ingreso de balones debe ser mayor a cero.")

        with get_connection() as db:
            db.execute(
                """
                UPDATE inventario
                SET llenos = llenos + ?,
                    entradas_mes = entradas_mes + ?,
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = 1
                """,
                (cantidad, cantidad),
            )
            db.execute(
                """
                INSERT INTO movimientos_inventario
                    (fecha, tipo, cantidad_llenos, referencia)
                VALUES (?, 'ingreso_manual', ?, ?)
                """,
                (fecha, cantidad, observaciones or "Ingreso manual de balones llenos"),
            )
            db.commit()
        flash("Ingreso de balones registrado correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")
    return redirect_to_dashboard(fecha, "ingresoGasForm")


@app.route("/inventario-agua", methods=["POST"])
def actualizar_inventario_agua():
    fecha = text_from_form("fecha") or today_iso()
    try:
        llenos = number_from_form("agua_llenos", integer=True)
        vacios = number_from_form("agua_vacios", integer=True)
        entradas_mes = number_from_form("agua_entradas_mes", integer=True)
        salidas_mes = number_from_form("agua_salidas_mes", integer=True)
        if min(llenos, vacios, entradas_mes, salidas_mes) < 0:
            raise ValueError("Los valores de inventario de agua no pueden ser negativos.")

        with get_connection() as db:
            db.execute(
                """
                UPDATE inventario_agua
                SET llenos = ?,
                    vacios = ?,
                    entradas_mes = ?,
                    salidas_mes = ?,
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = 1
                """,
                (llenos, vacios, entradas_mes, salidas_mes),
            )
            db.execute(
                """
                INSERT INTO movimientos_agua
                    (fecha, tipo, cantidad_llenos, cantidad_vacios, referencia)
                VALUES (?, 'ajuste', ?, ?, 'Ajuste manual de agua')
                """,
                (fecha, llenos, vacios),
            )
            db.commit()
        flash("Inventario de agua actualizado correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")
    return redirect_to_dashboard(fecha, "inventarioAguaForm")


@app.route("/prestamos", methods=["POST"])
def registrar_prestamo():
    fecha = text_from_form("fecha") or today_iso()
    try:
        cliente = text_from_form("cliente")
        tipo_cliente = text_from_form("tipo_cliente") or "cliente"
        tipo_balon = text_from_form("tipo_balon") or "lleno"
        cantidad = number_from_form("cantidad", integer=True)
        observaciones = text_from_form("observaciones")

        if not cliente:
            raise ValueError("Ingrese el cliente o mayorista.")
        if tipo_cliente not in {"cliente", "mayorista"}:
            raise ValueError("Seleccione un tipo de cliente valido.")
        if tipo_balon not in {"lleno", "vacio"}:
            raise ValueError("Seleccione un tipo de balon valido.")
        if cantidad <= 0:
            raise ValueError("La cantidad prestada debe ser mayor a cero.")

        with get_connection() as db:
            inventory = db.execute("SELECT llenos, vacios FROM inventario WHERE id = 1").fetchone()
            if tipo_balon == "lleno" and inventory["llenos"] < cantidad:
                raise ValueError("No hay balones llenos suficientes para prestar.")
            if tipo_balon == "vacio" and inventory["vacios"] < cantidad:
                raise ValueError("No hay balones vacios suficientes para prestar.")

            cursor = db.execute(
                """
                INSERT INTO prestamos
                    (fecha, cliente, tipo_cliente, tipo_balon, cantidad, observaciones)
                VALUES
                    (?, ?, ?, ?, ?, ?)
                """,
                (fecha, cliente, tipo_cliente, tipo_balon, cantidad, observaciones),
            )
            prestamo_id = cursor.lastrowid
            prestados_column = "prestados_mayoristas" if tipo_cliente == "mayorista" else "prestados_clientes"
            stock_column = "llenos" if tipo_balon == "lleno" else "vacios"
            db.execute(
                f"""
                UPDATE inventario
                SET {stock_column} = {stock_column} - ?,
                    {prestados_column} = {prestados_column} + ?,
                    salidas_mes = salidas_mes + ?,
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = 1
                """,
                (cantidad, cantidad, cantidad),
            )
            db.execute(
                """
                INSERT INTO movimientos_inventario
                    (fecha, tipo, cantidad_llenos, cantidad_vacios,
                     cantidad_prestados_clientes, cantidad_prestados_mayoristas, referencia)
                VALUES
                    (?, 'prestamo', ?, ?, ?, ?, ?)
                """,
                (
                    fecha,
                    -cantidad if tipo_balon == "lleno" else 0,
                    -cantidad if tipo_balon == "vacio" else 0,
                    cantidad if tipo_cliente == "cliente" else 0,
                    cantidad if tipo_cliente == "mayorista" else 0,
                    f"Prestamo #{prestamo_id}",
                ),
            )
            db.commit()
        flash("Prestamo registrado correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")
    return redirect_to_dashboard(fecha)


@app.route("/inventario", methods=["POST"])
def actualizar_inventario():
    fecha = text_from_form("fecha") or today_iso()
    try:
        llenos = number_from_form("llenos", integer=True)
        vacios = number_from_form("vacios", integer=True)
        prestados_clientes = number_from_form("prestados_clientes", integer=True)
        prestados_mayoristas = number_from_form("prestados_mayoristas", integer=True)
        entradas_mes = number_from_form("entradas_mes", integer=True)
        salidas_mes = number_from_form("salidas_mes", integer=True)

        if min(llenos, vacios, prestados_clientes, prestados_mayoristas, entradas_mes, salidas_mes) < 0:
            raise ValueError("Los valores de inventario no pueden ser negativos.")

        with get_connection() as db:
            db.execute(
                """
                UPDATE inventario
                SET llenos = ?,
                    vacios = ?,
                    prestados_clientes = ?,
                    prestados_mayoristas = ?,
                    entradas_mes = ?,
                    salidas_mes = ?,
                    updated_at = CURRENT_TIMESTAMP
                WHERE id = 1
                """,
                (llenos, vacios, prestados_clientes, prestados_mayoristas, entradas_mes, salidas_mes),
            )
            db.execute(
                """
                INSERT INTO movimientos_inventario
                    (fecha, tipo, cantidad_llenos, cantidad_vacios,
                     cantidad_prestados_clientes, cantidad_prestados_mayoristas, referencia)
                VALUES (?, 'ajuste', ?, ?, ?, ?, 'Ajuste manual de inventario')
                """,
                (fecha, llenos, vacios, prestados_clientes, prestados_mayoristas),
            )
            db.commit()
        flash("Inventario actualizado correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")

    return redirect_to_dashboard(fecha)


init_db()


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=int(os.getenv("PORT", 5000)), debug=os.getenv("FLASK_DEBUG") == "1")
