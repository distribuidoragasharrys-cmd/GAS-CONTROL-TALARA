@app.route("/gastos", methods=["POST"])
def registrar_gasto():
    fecha = text_from_form("fecha") or today_iso()
    try:
        concepto = text_from_form("concepto")
        categoria = text_from_form("categoria") or "General"
        monto = number_from_form("monto")
        observaciones = text_from_form("observaciones")

        if not concepto:
            raise ValueError("Ingrese el concepto del gasto.")
        if monto <= 0:
            raise ValueError("El monto del gasto debe ser mayor a cero.")

        with get_connection() as db:
            cursor = db.execute(
                """
                INSERT INTO gastos
                    (fecha, concepto, categoria, monto, observaciones)
                VALUES
                    (?, ?, ?, ?, ?)
                """,
                (fecha, concepto, categoria, monto, observaciones),
            )
            gasto_id = cursor.lastrowid
            record_account_movement(db, fecha, "caja", "egreso", monto, f"Gasto #{gasto_id} - {concepto}")
            db.commit()
        flash("Gasto registrado correctamente.", "success")
    except ValueError as error:
        flash(str(error), "danger")

    return redirect_to_dashboard(fecha)


@app.route("/gastos/<int:gasto_id>/editar", methods=["POST"])
