                <div class="calculation-strip liquidation-strip">
                  <span>Debe entregar: <strong id="driverExpectedPreview">S/ 0.00</strong></span>
                  <span>Entregando: <strong id="liquidationAmountPreview">S/ 0.00</strong></span>
                  <span>Diferencia: <strong id="driverDifferencePreview">S/ 0.00</strong></span>
                </div>
              </div>
