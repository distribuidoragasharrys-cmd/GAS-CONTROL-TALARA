<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sistema Gas | Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar" aria-label="Menu principal">
      <div class="brand">
        <div class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 32 32" role="img">
            <path d="M12 3h8v4l3 3v17a2 2 0 0 1-2 2H11a2 2 0 0 1-2-2V10l3-3V3Z"></path>
            <path d="M12 7h8"></path>
          </svg>
        </div>
        <div>
          <span>Distribuidora</span>
          <strong>Harrys</strong>
        </div>
      </div>

      <nav class="nav-list">
        <a class="nav-link active" href="{{ url_for('dashboard', fecha=selected_date) }}">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m3 11 9-8 9 8"></path><path d="M5 10v10h14V10"></path><path d="M9 20v-6h6v6"></path></svg>
          <span>Dashboard</span>
        </a>
        <a class="nav-link" href="#pedidoForm">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3h12v18H6z"></path><path d="M9 7h6"></path><path d="M9 11h6"></path><path d="M9 15h4"></path></svg>
          <span>Pedidos</span>
        </a>
        <a class="nav-link" href="#movementsTable">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6h15l-2 8H8L6 6Z"></path><path d="M6 6 5 3H2"></path><path d="M9 20h.01"></path><path d="M18 20h.01"></path></svg>
          <span>Ventas</span>
        </a>
        <a class="nav-link" href="#gastoForm">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16v12H4z"></path><path d="M8 7V5h8v2"></path><path d="M8 13h8"></path></svg>
          <span>Gastos</span>
        </a>
        <a class="nav-link" href="#repartidoresPanel">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><path d="M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"></path><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          <span>Repartidores</span>
        </a>
        <a class="nav-link" href="#inventarioForm">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 3h6v4H9z"></path><path d="M8 7h8l2 3v11H6V10l2-3Z"></path><path d="M10 14h4"></path></svg>
          <span>Inventario</span>
        </a>
        <a class="nav-link" href="#movementsTable">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 20V10"></path><path d="M12 20V4"></path><path d="M19 20v-7"></path></svg>
          <span>Reportes</span>
        </a>
      </nav>

      <form action="{{ url_for('logout') }}" method="post" class="logout-form">
      <button class="logout" type="submit">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 17 15 12l-5-5"></path><path d="M15 12H3"></path><path d="M14 4h5v16h-5"></path></svg>
        <span>Cerrar sesion</span>
      </button>
      </form>
    </aside>

    <main class="main-panel">
      <header class="topbar">
        <div>
          <button class="icon-button menu-button" type="button" aria-label="Abrir menu">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16"></path><path d="M4 12h16"></path><path d="M4 18h16"></path></svg>
          </button>
          <div>
            <p class="eyebrow">Panel operativo</p>
            <h1>Dashboard</h1>
          </div>
        </div>
        <div class="topbar-actions">
          <div class="date-chip">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3v3"></path><path d="M17 3v3"></path><path d="M4 8h16"></path><path d="M5 5h14v16H5z"></path></svg>
            <span id="todayLabel">{{ date_label }}</span>
          </div>
          <form class="date-filter" action="{{ url_for('dashboard') }}" method="get">
            <input class="form-control" type="date" name="fecha" value="{{ selected_date }}" aria-label="Filtrar por fecha">
            <button class="primary-button" type="submit">Filtrar</button>
          </form>
          <button class="user-menu" type="button">
            <span class="avatar">A</span>
            <span>Administrador</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
          </button>
        </div>
      </header>

      {% with messages = get_flashed_messages(with_categories=true) %}
        {% if messages %}
          <div class="flash-stack">
            {% for category, message in messages %}
              <div class="alert alert-{{ category }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      {% endwith %}

      <section class="summary-grid" aria-label="Resumen principal">
        <article class="metric-card metric-income">
          <div class="metric-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 19V5"></path><path d="m5 12 7-7 7 7"></path></svg>
          </div>
          <div>
            <span>Ingresos del dia</span>
            <strong id="incomeToday">{{ metrics.income_today|soles }}</strong>
            <small id="salesTodaySmall">{{ metrics.sales_today }} ventas del dia</small>
          </div>
        </article>

        <article class="metric-card metric-expense">
          <div class="metric-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14"></path><path d="m19 12-7 7-7-7"></path></svg>
          </div>
          <div>
            <span>Egresos del dia</span>
            <strong id="expenseToday">{{ metrics.expense_today|soles }}</strong>
            <small>Gastos registrados</small>
          </div>
        </article>

        <article class="metric-card metric-profit">
          <div class="metric-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16v11H4z"></path><path d="M7 7V5h10v2"></path><path d="M16 13h4"></path></svg>
          </div>
          <div>
            <span>Ganancia del dia</span>
            <strong id="profitToday">{{ metrics.profit_today|soles }}</strong>
            <small>Precio venta - costo</small>
          </div>
        </article>

        <article class="metric-card metric-stock">
          <div class="metric-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 3h6v4H9z"></path><path d="M8 7h8l2 3v11H6V10l2-3Z"></path><path d="M10 14h4"></path></svg>
          </div>
          <div>
            <span>Stock actual</span>
            <strong id="stockCurrent">{{ metrics.stock }}</strong>
            <small id="loanedSmall">{{ metrics.loaned_total }} balones prestados</small>
          </div>
        </article>
      </section>

      <section class="account-overview" aria-label="Resumen de cuentas">
        <article class="panel accounts-panel">
          <div class="panel-heading">
            <div>
              <p class="eyebrow">Control de cuentas</p>
              <h2>Saldos del dia</h2>
            </div>
            <span class="trend-pill" id="accountBalanceTotal">{{ account_summary.saldo_total|soles }}</span>
          </div>
          <div class="account-ledger">
            <div class="account-totals">
              <div>
                <span>Saldo inicial</span>
                <strong id="accountInitialTotal">{{ account_summary.saldo_inicial_total|soles }}</strong>
              </div>
              <div>
                <span>Ingresos a cuentas</span>
                <strong class="positive" id="accountIncomeMovements">{{ account_summary.ingresos|soles }}</strong>
              </div>
              <div>
                <span>Salidas de cuentas</span>
                <strong class="negative" id="accountExpenseMovements">{{ account_summary.egresos|soles }}</strong>
              </div>
              <div>
                <span>Saldo actual</span>
                <strong id="accountCurrentTotal">{{ account_summary.saldo_total|soles }}</strong>
              </div>
            </div>
            <div class="account-flow" aria-label="Grafico de ingresos y salidas">
              <div>
                <span>Ingresos</span>
                <i id="accountIncomeBar" style="width: 0%"></i>
              </div>
              <div>
                <span>Salidas</span>
                <i class="outflow" id="accountExpenseBar" style="width: 0%"></i>
              </div>
            </div>
            <div class="account-list" id="accountsList"></div>
          </div>
        </article>
      </section>

      <datalist id="driversList">
        {% for driver in drivers %}
          <option value="{{ driver.nombre }}"></option>
        {% endfor %}
      </datalist>

      <section class="forms-grid" id="formularios" aria-label="Formularios de registro">
        <article class="panel form-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Pedidos</p>
              <h2>Nuevo pedido</h2>
            </div>
          </div>
          <form id="pedidoForm" action="{{ url_for('registrar_pedido') }}" method="post" class="dashboard-form">
            <div class="row g-3">
              <div class="col-sm-6">
                <label class="form-label" for="pedidoFecha">Fecha</label>
                <input class="form-control" id="pedidoFecha" name="fecha" type="date" value="{{ selected_date }}">
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="pedidoCantidad">Cantidad</label>
                <input class="form-control order-calculator" id="pedidoCantidad" name="cantidad" type="number" min="1" step="1" value="1" required>
              </div>
              <div class="col-12">
                <label class="form-label" for="pedidoProducto">Producto</label>
                <select class="form-select order-calculator" id="pedidoProducto" name="producto" required>
                  <optgroup label="Gas">
                    <option value="BALON DE GAS 10 KG">BALON DE GAS 10 KG</option>
                    <option value="CARGA DE GAS 10 KG">CARGA DE GAS 10 KG</option>
                    <option value="BALON DE GAS 45 KG">BALON DE GAS 45 KG</option>
                    <option value="CARGA DE GAS 45 KG">CARGA DE GAS 45 KG</option>
                  </optgroup>
                  <optgroup label="Agua">
                    <option value="BIDON DE AGUA">BIDON DE AGUA</option>
                    <option value="CARGA DE AGUA">CARGA DE AGUA</option>
                  </optgroup>
                </select>
              </div>
              <div class="col-12" id="pedidoValveGroup">
                <label class="form-label" for="pedidoTipoValvula">Valvula</label>
                <select class="form-select" id="pedidoTipoValvula" name="tipo_valvula">
                  <option value="VALVULA NORMAL">VALVULA NORMAL</option>
                  <option value="VALVULA PREMIUM">VALVULA PREMIUM</option>
                </select>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="pedidoCliente">Cliente</label>
                <input class="form-control" id="pedidoCliente" name="cliente" type="text" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="pedidoTelefono">Telefono</label>
                <input class="form-control" id="pedidoTelefono" name="telefono" type="text">
              </div>
              <div class="col-12">
                <label class="form-label" for="pedidoDireccion">Direccion</label>
                <input class="form-control" id="pedidoDireccion" name="direccion" type="text" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="pedidoCosto">Costo producto</label>
                <input class="form-control order-calculator" id="pedidoCosto" name="costo_producto" type="number" min="0" step="0.01" value="{{ daily_price.costo_balon }}" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="pedidoPrecio">Precio venta</label>
                <input class="form-control order-calculator" id="pedidoPrecio" name="precio_venta" type="number" min="0" step="0.01" value="{{ daily_price.precio_venta }}" required>
              </div>
              <div class="col-12">
                <div class="section-divider">Producto adicional opcional</div>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="pedidoProductoExtra">Producto adicional</label>
                <select class="form-select order-calculator" id="pedidoProductoExtra" name="producto_extra">
                  <option value="">Sin producto adicional</option>
                  <optgroup label="Gas">
                    <option value="BALON DE GAS 10 KG">BALON DE GAS 10 KG</option>
                    <option value="CARGA DE GAS 10 KG">CARGA DE GAS 10 KG</option>
                    <option value="BALON DE GAS 45 KG">BALON DE GAS 45 KG</option>
                    <option value="CARGA DE GAS 45 KG">CARGA DE GAS 45 KG</option>
                  </optgroup>
                  <optgroup label="Agua">
                    <option value="BIDON DE AGUA">BIDON DE AGUA</option>
                    <option value="CARGA DE AGUA">CARGA DE AGUA</option>
                  </optgroup>
                </select>
              </div>
              <div class="col-sm-6" id="pedidoValveExtraGroup">
                <label class="form-label" for="pedidoTipoValvulaExtra">Valvula adicional</label>
                <select class="form-select order-calculator" id="pedidoTipoValvulaExtra" name="tipo_valvula_extra">
                  <option value="VALVULA NORMAL">VALVULA NORMAL</option>
                  <option value="VALVULA PREMIUM">VALVULA PREMIUM</option>
                </select>
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="pedidoCantidadExtra">Cantidad adicional</label>
                <input class="form-control order-calculator" id="pedidoCantidadExtra" name="cantidad_extra" type="number" min="0" step="1" value="0">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="pedidoCostoExtra">Costo adicional</label>
                <input class="form-control order-calculator" id="pedidoCostoExtra" name="costo_producto_extra" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="pedidoPrecioExtra">Precio adicional</label>
                <input class="form-control order-calculator" id="pedidoPrecioExtra" name="precio_venta_extra" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="col-12">
                <div class="calculation-strip">
                  <span>Total pedido: <strong id="newOrderTotalPreview">S/ 0.00</strong></span>
                  <span>Ganancia: <strong id="newOrderProfitPreview">S/ 0.00</strong></span>
                  <span>Tipo: <strong id="newOrderTypePreview">Gas</strong></span>
                </div>
              </div>
              <div class="col-12">
                <label class="form-label" for="pedidoObservaciones">Observaciones</label>
                <input class="form-control" id="pedidoObservaciones" name="observaciones" type="text">
              </div>
            </div>
            <button class="primary-button form-submit" type="submit">Registrar pedido</button>
          </form>
        </article>

        <article class="panel workflow-panel wide-panel" id="pedidosPanel">
          <div class="panel-heading">
            <div>
              <p class="eyebrow">Flujo operativo</p>
              <h2>Lista de pedidos</h2>
            </div>
            <a class="primary-button export-link" href="{{ url_for('exportar_reporte', modulo='pedidos', fecha=selected_date) }}">Exportar pedidos</a>
          </div>
          <div class="workflow-stats">
            <div>
              <span>Pendientes</span>
              <strong id="ordersPending">{{ orders.counts.pendiente }}</strong>
            </div>
            <div>
              <span>En ruta</span>
              <strong id="ordersRoute">{{ orders.counts.en_ruta }}</strong>
            </div>
            <div>
              <span>Entregados</span>
              <strong id="ordersDelivered">{{ orders.counts.entregado }}</strong>
            </div>
            <div>
              <span>Liquidados</span>
              <strong id="ordersSettled">{{ orders.counts.liquidado }}</strong>
            </div>
            <div>
              <span>Anulados</span>
              <strong id="ordersCancelled">{{ orders.counts.anulado }}</strong>
            </div>
          </div>
          <div class="quick-filters sticky-filters">
            <label>
              <span>Estado</span>
              <select class="form-select form-select-sm" id="orderFilterStatus">
                <option value="">Todos</option>
                <option value="pendiente">Pendiente</option>
                <option value="en_ruta">En ruta</option>
                <option value="entregado">Entregado</option>
                <option value="liquidado">Liquidado</option>
                <option value="anulado">Anulado</option>
              </select>
            </label>
            <label>
              <span>Repartidor</span>
              <input class="form-control form-control-sm" id="orderFilterDriver" type="search" placeholder="Buscar">
            </label>
            <label>
              <span>Fecha</span>
              <input class="form-control form-control-sm" id="orderFilterDate" type="date" value="{{ selected_date }}">
            </label>
          </div>
          <div class="table-wrap compact-table">
            <table class="orders-table">
              <thead>
                <tr>
                  <th>Pedido</th>
                  <th>Cliente</th>
                  <th>Direccion</th>
                  <th>Producto</th>
                  <th>Importe</th>
                  <th>Estado</th>
                  <th>Repartidor</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="ordersTable"></tbody>
            </table>
          </div>
        </article>

        <article class="panel form-panel wide-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Pedidos</p>
              <h2>Gestion rapida</h2>
            </div>
          </div>
          <form id="gestionPedidoForm" action="{{ url_for('gestionar_pedido') }}" method="post" class="dashboard-form">
            <input type="hidden" name="fecha" value="{{ selected_date }}">
            <input type="hidden" name="accion_pedido" value="liquidar">
            <div class="row g-3">
              <div class="col-lg-6">
                <label class="form-label" for="gestionPedido">Pedido</label>
                <select class="form-select liquidation-calculator" id="gestionPedido" name="pedido_id" required>
                  <option value="" data-total="0" data-efectivo="0">Seleccionar pedido</option>
                  {% for pedido in orders.latest %}
                    {% if pedido.estado in ["pendiente", "en_ruta", "entregado"] %}
                      <option value="{{ pedido.id }}" data-total="{{ pedido.total_venta or (pedido.precio_venta * pedido.cantidad) }}" data-repartidor="{{ pedido.repartidor }}" data-estado="{{ pedido.estado }}">#{{ pedido.id }} - {{ pedido.cliente }} / {{ pedido.items_resumen }}</option>
                    {% endif %}
                  {% endfor %}
                </select>
              </div>
              <div class="col-lg-6">
                <label class="form-label" for="gestionRepartidor">Repartidor</label>
                <input class="form-control" id="gestionRepartidor" name="repartidor" type="text" list="driversList">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="liq_pago_efectivo">Efectivo</label>
                <input class="form-control liquidation-calculator" id="liq_pago_efectivo" name="pago_efectivo" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="liq_pago_yape">Yape</label>
                <input class="form-control liquidation-calculator" id="liq_pago_yape" name="pago_yape" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="liq_pago_yape_marcos">Yape Marcos</label>
                <input class="form-control liquidation-calculator" id="liq_pago_yape_marcos" name="pago_yape_marcos" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="liq_pago_plin">Plin</label>
                <input class="form-control liquidation-calculator" id="liq_pago_plin" name="pago_plin" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="liq_pago_fise">FISE</label>
                <input class="form-control liquidation-calculator" id="liq_pago_fise" name="pago_fise" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="liq_fise_20">FISE S/ 20</label>
                <input class="form-control liquidation-calculator" id="liq_fise_20" name="fise_20_cantidad" type="number" min="0" step="1" value="0">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="liq_fise_43">FISE S/ 43</label>
                <input class="form-control liquidation-calculator" id="liq_fise_43" name="fise_43_cantidad" type="number" min="0" step="1" value="0">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="liq_pago_fiado">Fiado</label>
                <input class="form-control liquidation-calculator" id="liq_pago_fiado" name="pago_fiado" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="col-sm-4">
                <label class="form-label" for="liq_vuelto_yape">Vuelto por Yape</label>
                <input class="form-control liquidation-calculator" id="liq_vuelto_yape" name="vuelto_yape" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="liq_dinero_entregado">Dinero entregado</label>
                <input class="form-control liquidation-calculator" id="liq_dinero_entregado" name="dinero_entregado" type="number" min="0" step="0.01" value="0">
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="gestionObservaciones">Observaciones</label>
                <input class="form-control" id="gestionObservaciones" name="observaciones" type="text">
              </div>
              <div class="col-12">
                <div class="calculation-strip liquidation-strip">
                  <span>Total vendido: <strong id="orderTotalPreview">S/ 0.00</strong></span>
                  <span>Total cobrado: <strong id="orderCollectedPreview">S/ 0.00</strong></span>
                  <span>Saldo pendiente: <strong id="orderPendingPreview">S/ 0.00</strong></span>
                  <span>Diferencia rep.: <strong id="orderDifferencePreview">S/ 0.00</strong></span>
                  <span>FISES: <strong id="orderFisePreview">0 / S/ 0.00</strong></span>
                  <span>Vuelto Yape: <strong id="orderYapeChangePreview">S/ 0.00</strong></span>
                </div>
              </div>
            </div>
            <button class="primary-button form-submit" type="submit">Liquidar pedido</button>
          </form>
        </article>

        <article class="panel form-panel">
          <div class="panel-heading compact">
            <div>
              <p class="eyebrow">Precio variable</p>
              <h2>Precio del dia</h2>
            </div>
          </div>
          <form id="precioForm" action="{{ url_for('registrar_precio') }}" method="post" class="dashboard-form">
            <div class="row g-3">
              <div class="col-sm-6">
