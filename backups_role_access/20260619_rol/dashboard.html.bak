          </div>
          <form id="inventarioForm" action="{{ url_for('actualizar_inventario') }}" method="post" class="dashboard-form">
            <input type="hidden" name="fecha" value="{{ selected_date }}">
            <div class="row g-3">
              <div class="col-sm-6">
                <label class="form-label" for="llenos">Llenos</label>
                <input class="form-control" id="llenos" name="llenos" type="number" min="0" step="1" value="{{ inventory.llenos }}" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="vacios">Vacios</label>
                <input class="form-control" id="vacios" name="vacios" type="number" min="0" step="1" value="{{ inventory.vacios }}" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="prestados_clientes">Prestados clientes</label>
                <input class="form-control" id="prestados_clientes" name="prestados_clientes" type="number" min="0" step="1" value="{{ inventory.prestados_clientes }}" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="prestados_mayoristas">Prestados mayoristas</label>
                <input class="form-control" id="prestados_mayoristas" name="prestados_mayoristas" type="number" min="0" step="1" value="{{ inventory.prestados_mayoristas }}" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="entradas_mes">Entradas mes</label>
                <input class="form-control" id="entradas_mes" name="entradas_mes" type="number" min="0" step="1" value="{{ inventory.entradas_mes }}" required>
              </div>
              <div class="col-sm-6">
                <label class="form-label" for="salidas_mes">Salidas mes</label>
                <input class="form-control" id="salidas_mes" name="salidas_mes" type="number" min="0" step="1" value="{{ inventory.salidas_mes }}" required>
